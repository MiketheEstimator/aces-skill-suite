from lxml import etree


def validate_dimensional_facts(model_xbrl) -> list[dict]:
    """
    Validate dimensional (hypercube) facts against the definition linkbase.

    Checks:
    1. All explicit members are defined in the taxonomy as domain members
    2. Closed hypercubes: no undeclared dimension members allowed
    3. Default members: facts missing a dimension use the declared default
    4. Typed dimensions: member values conform to declared XSD type
    """
    from arelle.ValidateXbrlDimensions import ValidateXbrlDimensions
    v = ValidateXbrlDimensions(model_xbrl)
    v.validate()
    return [
        {
            'concept':     str(e.concept.qname) if hasattr(e, 'concept') else '',
            'dimension':   str(e.dimension)      if hasattr(e, 'dimension') else '',
            'member':      str(e.member)          if hasattr(e, 'member') else '',
            'context_ref': getattr(e, 'contextID', ''),
            'code':        getattr(e, 'code', ''),
        }
        for e in getattr(model_xbrl, 'dimensionErrors', [])
    ]


def build_dimensional_context_xml(
    entity_cik: str,
    period_type: str,      # 'instant' | 'duration'
    period_end:  str,      # '2024-12-31'
    dimensions:  dict,     # {'axis_qname': 'member_qname', ...}
    period_start: str = None,
    context_id:   str = None,
) -> str:
    """
    Build a well-formed XBRL context element with explicit dimension members.

    dimensions example:
        {
            'us-gaap:StatementBusinessSegmentsAxis': 'acme:NorthAmericaSegmentMember',
            'us-gaap:ProductOrServiceAxis':          'us-gaap:ProductMember',
        }

    Rules:
    - axis qname must be declared as a hypercube dimension in the definition linkbase
    - member qname must be a valid domain member in that axis
    - context_id must be unique within the instance document
    """
    if context_id is None:
        suffix = '_'.join(v.split(':')[-1][:8] for v in dimensions.values())
        context_id = f"ctx_{period_end.replace('-','')}_{suffix}"

    if period_type == 'instant':
        period_xml = (
            '<xbrli:period>'
            f'<xbrli:instant>{period_end}</xbrli:instant>'
            '</xbrli:period>'
        )
    else:
        period_xml = (
            '<xbrli:period>'
            f'<xbrli:startDate>{period_start}</xbrli:startDate>'
            f'<xbrli:endDate>{period_end}</xbrli:endDate>'
            '</xbrli:period>'
        )

    members = '\n      '.join(
        f'<xbrldi:explicitMember dimension="{ax}">{mem}</xbrldi:explicitMember>'
        for ax, mem in dimensions.items()
    )

    return (
        f'<xbrli:context id="{context_id}">\n'
        f'  <xbrli:entity>\n'
        f'    <xbrli:identifier scheme="http://www.sec.gov/cik">'
        f'{entity_cik}</xbrli:identifier>\n'
        f'    <xbrli:segment>\n'
        f'      {members}\n'
        f'    </xbrli:segment>\n'
        f'  </xbrli:entity>\n'
        f'  {period_xml}\n'
        f'</xbrli:context>'
    )
