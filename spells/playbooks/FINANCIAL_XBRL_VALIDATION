## Instance Validation (Arelle)

```python
from pathlib import Path
from arelle import Cntlr, ModelManager, FileSource
import json


def load_xbrl_document(instance_path: str | Path,
                        cache_dir: str | Path = '/tmp/arelle_cache'):
    """
    Load an XBRL or iXBRL instance document and resolve its full DTS.

    DTS (Discoverable Taxonomy Set) = all schemas and linkbases imported
    transitively from the instance document's schemaRef element.
    Must be fully resolved before any validation is meaningful.

    Returns (cntlr, model_xbrl).
    """
    path = Path(instance_path)
    assert path.exists(), f'Instance not found: {path}'

    cntlr = Cntlr.Cntlr(logFileName='logToPrint')
    cntlr.startLogging(logFileName='logToPrint')
    cntlr.webCache.cacheDir = str(cache_dir)

    model_mgr  = ModelManager.initialize(cntlr)
    model_xbrl = model_mgr.load(FileSource.openFileSource(str(path), cntlr))
    return cntlr, model_xbrl


def validate_instance(instance_path: str | Path,
                       validate_calcs: bool = True) -> dict:
    """
    Full XBRL 2.1 + SEC EFM validation of an instance document.
    validate_calcs=True runs calculation linkbase consistency checks.

    Returns structured report: status, errors, warnings, fact/context counts,
    calculation inconsistencies.
    """
    cntlr, model_xbrl = load_xbrl_document(instance_path)

    errors, warnings = [], []
    for rec in cntlr.logHandler.logRecordBuffer:
        lvl   = rec.levelname.upper()
        entry = {
            'code':    getattr(rec, 'messageCode', ''),
            'message': rec.getMessage(),
            'refs':    getattr(rec, 'refs', []),
        }
        if lvl in ('ERROR', 'CRITICAL'):
            errors.append(entry)
        elif lvl == 'WARNING':
            warnings.append(entry)

    facts = [
        {
            'concept':  str(f.concept.qname) if f.concept else 'unknown',
            'context':  f.contextID,
            'value':    f.value,
            'decimals': f.decimals,
            'unit':     str(f.unitID) if f.unitID else None,
        }
        for f in model_xbrl.facts
    ]

    calc_issues = _run_calc_check(model_xbrl) if validate_calcs else []

    report = {
        'instance_path': str(instance_path),
        'status':        'pass' if not errors and not calc_issues else 'fail',
        'error_count':   len(errors),
        'warning_count': len(warnings),
        'fact_count':    len(facts),
        'context_count': len(model_xbrl.contexts),
        'errors':        errors,
        'warnings':      warnings[:20],
        'calc_issues':   calc_issues,
    }

    path_name = Path(instance_path).name
    print(f'\nXBRL Validation: {path_name}')
    print(f'  Status:   {report["status"].upper()}')
    print(f'  Facts:    {report["fact_count"]:,}')
    print(f'  Contexts: {report["context_count"]}')
    print(f'  Errors:   {report["error_count"]}')
    print(f'  Warnings: {report["warning_count"]}')
    if calc_issues:
        print(f'  Calc failures: {len(calc_issues)}')

    model_xbrl.close()
    return report


def _run_calc_check(model_xbrl) -> list[dict]:
    """
    Run Arelle calculation linkbase consistency check.
    XBRL spec tolerance: |reported - computed| <= max(0.5, |reported| * 0.0005)
    """
    from arelle.ValidateXbrlCalcs import ValidateXbrlCalcs
    v = ValidateXbrlCalcs(model_xbrl)
    v.validate()
    return [
        {
            'parent':   str(i.concept.qname),
            'context':  i.contextID,
            'reported': i.factValue,
            'computed': i.computedValue,
            'delta':    i.delta,
        }
        for i in getattr(model_xbrl, 'calcInconsistencies', [])
    ]
