```python
from lxml import etree
from pathlib import Path


def build_extension_schema(
    company_prefix:    str,   # e.g. 'acme'
    company_namespace: str,   # e.g. 'http://www.acme.com/20241231'
    period_end_date:   str,   # '2024-12-31'
    base_taxonomy_href: str,  # URL to us-gaap-2024.xsd entry point
    custom_elements:   list[dict],
    output_dir:        str | Path,
) -> Path:
    """
    Build a company extension taxonomy XSD.

    custom_elements item keys:
        name              PascalCase (e.g. 'AdjustedEBITDA')
        type              XSD type (default: 'xbrli:monetaryItemType')
        period_type       'duration' | 'instant'
        balance           'credit' | 'debit'  (required for monetary types)
        abstract          bool — True for header/subtotal line items
        substitution_group (default: 'xbrli:item')

    Extension rules:
    - Namespace must be unique and period-dated (http://company.com/YYYYMMDD)
    - Never duplicate existing us-gaap elements
    - Monetary elements must declare balance (debit or credit)
    - All four linkbases must be listed in the annotation/appinfo block
    """
    out      = Path(output_dir)
    out.mkdir(parents=True, exist_ok=True)
    date_str = period_end_date.replace('-', '')
    xsd_file = out / f'{company_prefix}-{date_str}.xsd'

    XS    = 'http://www.w3.org/2001/XMLSchema'
    XBRLI = 'http://www.xbrl.org/2003/instance'
    LINK  = 'http://www.xbrl.org/2003/linkbase'
    XLINK = 'http://www.w3.org/1999/xlink'

    nsmap = {None: company_namespace, 'xs': XS,
             'xbrli': XBRLI, 'link': LINK, 'xlink': XLINK}
    schema = etree.Element(f'{{{XS}}}schema', nsmap=nsmap)
    schema.set('targetNamespace',    company_namespace)
    schema.set('elementFormDefault', 'qualified')

    for ns_uri, href in [
        (XBRLI, 'http://www.xbrl.org/2003/xbrl-instance-2003-12-31.xsd'),
        ('http://fasb.org/us-gaap/2024', base_taxonomy_href),
    ]:
        imp = etree.SubElement(schema, f'{{{XS}}}import')
        imp.set('namespace',     ns_uri)
        imp.set('schemaLocation', href)

    annotation = etree.SubElement(schema, f'{{{XS}}}annotation')
    appinfo    = etree.SubElement(annotation, f'{{{XS}}}appinfo')
    for suffix, role_name in [
        ('cal', 'CalculationLinkbaseRef'), ('def', 'DefinitionLinkbaseRef'),
        ('lab', 'LabelLinkbaseRef'),       ('pre', 'PresentationLinkbaseRef'),
    ]:
        lb = etree.SubElement(appinfo, f'{{{LINK}}}linkbaseRef')
        lb.set(f'{{{XLINK}}}type',    'simple')
        lb.set(f'{{{XLINK}}}href',    f'{company_prefix}-{date_str}_{suffix}.xml')
        lb.set(f'{{{XLINK}}}role',    f'http://www.xbrl.org/2003/role/{role_name}')
        lb.set(f'{{{XLINK}}}arcrole', 'http://www.w3.org/1999/xlink/properties/linkbase')

    for elem in custom_elements:
        el = etree.SubElement(schema, f'{{{XS}}}element')
        el.set('name',              elem['name'])
        el.set('type',              elem.get('type', 'xbrli:monetaryItemType'))
        el.set('substitutionGroup', elem.get('substitution_group', 'xbrli:item'))
        el.set('id',                f"{company_prefix}_{elem['name']}")
        el.set(f'{{{XBRLI}}}periodType', elem.get('period_type', 'duration'))
        if elem.get('balance'):
            el.set(f'{{{XBRLI}}}balance', elem['balance'])
        if elem.get('abstract', False):
            el.set('abstract', 'true')
            el.set('nillable', 'true')

    etree.ElementTree(schema).write(
        str(xsd_file), pretty_print=True, xml_declaration=True, encoding='UTF-8'
    )
    print(f'  Extension schema: {xsd_file.name}')
    return xsd_file


def build_label_linkbase(
    company_prefix:    str,
    company_namespace: str,
    period_end_date:   str,
    labels:            list[dict],
    output_dir:        str | Path,
) -> Path:
    """
    Build a label linkbase for custom extension elements.

    labels item keys:
        element_name    Matches 'name' in the XSD
        label           Standard label text
        total_label     'Total X' label (optional)
        lang            BCP 47 tag (default: 'en-US')
    """
    out      = Path(output_dir)
    date_str = period_end_date.replace('-', '')
    lb_file  = out / f'{company_prefix}-{date_str}_lab.xml'

    LINK  = 'http://www.xbrl.org/2003/linkbase'
    XLINK = 'http://www.w3.org/1999/xlink'
    XSI   = 'http://www.w3.org/2001/XMLSchema-instance'
    XML   = 'http://www.w3.org/XML/1998/namespace'

    nsmap = {'link': LINK, 'xlink': XLINK, 'xsi': XSI}
    root  = etree.Element(f'{{{LINK}}}linkbase', nsmap=nsmap)
    root.set(f'{{{XSI}}}schemaLocation',
        'http://www.xbrl.org/2003/linkbase '
        'http://www.xbrl.org/2003/xbrl-linkbase-2003-12-31.xsd')

    ll = etree.SubElement(root, f'{{{LINK}}}labelLink')
    ll.set(f'{{{XLINK}}}type', 'extended')
    ll.set(f'{{{XLINK}}}role', 'http://www.xbrl.org/2003/role/link')

    ROLES = [
        ('label',      'http://www.xbrl.org/2003/role/label'),
        ('total_label','http://www.xbrl.org/2003/role/totalLabel'),
    ]

    for lbl in labels:
        elem_id = f"{company_prefix}_{lbl['element_name']}"
        lang    = lbl.get('lang', 'en-US')

        loc = etree.SubElement(ll, f'{{{LINK}}}loc')
        loc.set(f'{{{XLINK}}}type',  'locator')
        loc.set(f'{{{XLINK}}}href',  f'{company_prefix}-{date_str}.xsd#{elem_id}')
        loc.set(f'{{{XLINK}}}label', f'loc_{elem_id}')

        for role_key, role_uri in ROLES:
            text = lbl.get(role_key)
            if not text:
                continue
            res_id = f'lbl_{elem_id}_{role_key}'

            res = etree.SubElement(ll, f'{{{LINK}}}label')
            res.set(f'{{{XLINK}}}type',  'resource')
            res.set(f'{{{XLINK}}}label', res_id)
            res.set(f'{{{XLINK}}}role',  role_uri)
            res.set(f'{{{XML}}}lang',    lang)
            res.text = text

            arc = etree.SubElement(ll, f'{{{LINK}}}labelArc')
            arc.set(f'{{{XLINK}}}type',    'arc')
            arc.set(f'{{{XLINK}}}arcrole', 'http://www.xbrl.org/2003/arcrole/concept-label')
            arc.set(f'{{{XLINK}}}from',    f'loc_{elem_id}')
            arc.set(f'{{{XLINK}}}to',      res_id)

    etree.ElementTree(root).write(
        str(lb_file), pretty_print=True, xml_declaration=True, encoding='UTF-8'
    )
    print(f'  Label linkbase: {lb_file.name}')
    return lb_file
