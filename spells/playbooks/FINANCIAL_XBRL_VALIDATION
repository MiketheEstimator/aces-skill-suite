## lxml Instance Parsing

Fast fact extraction without full Arelle DTS resolution.
Use Arelle for validation; use lxml for high-throughput data pipelines.

```python
from lxml import etree
from pathlib import Path
from dataclasses import dataclass, field
from typing import Optional
import pandas as pd

NS_INSTANCE = 'http://www.xbrl.org/2003/instance'
NS_XBRLDI   = 'http://xbrl.org/2006/xbrldi'


@dataclass
class XbrlContext:
    context_id:   str
    period_type:  str            # 'instant' | 'duration'
    instant_date: Optional[str] = None
    start_date:   Optional[str] = None
    end_date:     Optional[str] = None
    dimensions:   dict = field(default_factory=dict)


@dataclass
class XbrlFact:
    local_name:  str
    namespace:   str
    context_ref: str
    unit_ref:    Optional[str]
    value:       str
    decimals:    Optional[str]


def parse_instance_lxml(instance_path: str | Path) -> dict:
    """
    Parse an XBRL instance document with lxml.
    Returns {contexts: dict, units: dict, facts: list[XbrlFact]}.
    """
    root = etree.parse(str(instance_path)).getroot()

    # Contexts
    contexts: dict[str, XbrlContext] = {}
    for ctx in root.findall(f'{{{NS_INSTANCE}}}context'):
        ctx_id = ctx.get('id')
        period = ctx.find(f'{{{NS_INSTANCE}}}period')
        if period is None:
            continue
        instant = period.find(f'{{{NS_INSTANCE}}}instant')
        start   = period.find(f'{{{NS_INSTANCE}}}startDate')
        end     = period.find(f'{{{NS_INSTANCE}}}endDate')
        obj = XbrlContext(context_id=ctx_id, period_type='')
        if instant is not None:
            obj.period_type  = 'instant'
            obj.instant_date = instant.text
        elif start is not None and end is not None:
            obj.period_type = 'duration'
            obj.start_date  = start.text
            obj.end_date    = end.text
        segment = ctx.find(f'.//{{{NS_INSTANCE}}}segment')
        if segment is not None:
            for m in segment:
                dim = m.get('dimension', '')
                obj.dimensions[dim] = (m.text or '').strip()
        contexts[ctx_id] = obj

    # Units
    units: dict[str, str] = {}
    for unit in root.findall(f'{{{NS_INSTANCE}}}unit'):
        uid     = unit.get('id')
        measure = unit.find(f'{{{NS_INSTANCE}}}measure')
        if measure is not None:
            units[uid] = measure.text or ''

    # Facts
    SKIP = {'context', 'unit', 'schemaRef', 'linkbaseRef'}
    facts: list[XbrlFact] = []
    for child in root:
        tag = child.tag
        if '}' not in tag:
            continue
        ns, local = tag[1:].split('}', 1)
        if local in SKIP:
            continue
        ctx_ref = child.get('contextRef')
        value   = (child.text or '').strip()
        if ctx_ref and value:
            facts.append(XbrlFact(
                local_name  = local,
                namespace   = ns,
                context_ref = ctx_ref,
                unit_ref    = child.get('unitRef'),
                value       = value,
                decimals    = child.get('decimals'),
            ))

    return {'contexts': contexts, 'units': units, 'facts': facts}


def facts_to_dataframe(parsed: dict) -> pd.DataFrame:
    """Flatten parsed XBRL facts into a tidy DataFrame for analysis."""
    rows = []
    for f in parsed['facts']:
        ctx = parsed['contexts'].get(f.context_ref)
        rows.append({
            'concept':      f.local_name,
            'namespace':    f.namespace.split('/')[-1],
            'context_ref':  f.context_ref,
            'period_type':  ctx.period_type if ctx else '',
            'period_date':  (ctx.instant_date or ctx.end_date) if ctx else None,
            'period_start': ctx.start_date if ctx else None,
            'unit_ref':     f.unit_ref,
            'value':        f.value,
            'decimals':     f.decimals,
            'dimensions':   str(ctx.dimensions) if ctx and ctx.dimensions else '',
        })
    df = pd.DataFrame(rows)

    def safe_num(v):
        try:
            return float(v)
        except (ValueError, TypeError):
            return None

    df['numeric_value'] = df['value'].apply(safe_num)
    df['period_date']   = pd.to_datetime(df['period_date'], errors='coerce')
    return df
