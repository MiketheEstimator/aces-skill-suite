## Taxonomy Traversal

```python
def get_presentation_network(model_xbrl, role_uri: str = None) -> list[dict]:
    """
    Walk the presentation linkbase to recover statement display structure.

    role_uri: restrict to one statement role URI. Common SEC roles:
      .../role/StatementOfIncome
      .../role/BalanceSheet
      .../role/StatementOfCashFlows
      .../role/StatementOfStockholdersEquity
    Pass None to return arcs for all roles.

    Returns list of {role, parent_qname, child_qname, order,
                     preferred_label, depth} dicts, sorted by (role, order).
    """
    PARENT_CHILD = 'http://www.xbrl.org/2003/arcrole/parent-child'
    rows = []

    for (arcrole, ELR, _lq, _aq) in model_xbrl.baseSets.keys():
        if arcrole != PARENT_CHILD:
            continue
        if role_uri and ELR != role_uri:
            continue

        network = model_xbrl.relationshipSet(arcrole, ELR)
        child_to_parent = {
            id(rel.toModelObject): rel.fromModelObject
            for rel in network.modelRelationships
            if rel.toModelObject
        }

        for rel in network.modelRelationships:
            depth, node = 0, rel.toModelObject
            while node and id(node) in child_to_parent:
                node = child_to_parent[id(node)]
                depth += 1

            rows.append({
                'role':            ELR,
                'parent_qname':    str(rel.fromModelObject.qname) if rel.fromModelObject else None,
                'child_qname':     str(rel.toModelObject.qname)   if rel.toModelObject   else None,
                'order':           float(rel.order or 0),
                'preferred_label': rel.preferredLabel,
                'depth':           depth,
            })

    return sorted(rows, key=lambda x: (x['role'], x['order']))


def get_calculation_arcs(model_xbrl, role_uri: str) -> list[dict]:
    """
    Return all calculation arcs for a statement role.
    weight: +1.0 = child adds to parent; -1.0 = child subtracts from parent.

    Example: OperatingIncomeLoss (+1) and IncomeTaxExpenseBenefit (-1)
    both feed into NetIncomeLoss parent.
    """
    SUMMATION = 'http://www.xbrl.org/2003/arcrole/summation-item'
    network   = model_xbrl.relationshipSet(SUMMATION, role_uri)
    arcs = []
    for rel in network.modelRelationships:
        arcs.append({
            'parent': str(rel.fromModelObject.qname),
            'child':  str(rel.toModelObject.qname),
            'weight': float(rel.weight),
            'order':  float(rel.order or 0),
            'role':   role_uri,
        })
    return sorted(arcs, key=lambda x: x['order'])


def get_concept_label(
    model_xbrl,
    concept_qname: str,
    label_role: str = 'http://www.xbrl.org/2003/role/label',
    lang: str = 'en-US',
) -> str:
    """
    Look up the human-readable label for a concept qname.

    Standard label roles:
      http://www.xbrl.org/2003/role/label              Standard label
      http://www.xbrl.org/2003/role/totalLabel         'Total X'
      http://www.xbrl.org/2003/role/negatedLabel       '(X)' for expenses
      http://www.xbrl.org/2009/role/negatedTotalLabel  'Total (X)'
      http://www.xbrl.org/2003/role/periodStartLabel   'Beginning balance'
      http://www.xbrl.org/2003/role/periodEndLabel     'Ending balance'
      http://www.xbrl.org/2003/role/verboseLabel       Long description
    """
    for concept in model_xbrl.qnameConcepts.values():
        if str(concept.qname) == concept_qname:
            return concept.label(
                preferredLabel=label_role,
                lang=lang,
                fallbackToQname=True,
            )
    return concept_qname


def reconstruct_statement(
    model_xbrl,
    role_uri: str,
    facts_df: 'pd.DataFrame',
    period_date: str,
) -> 'pd.DataFrame':
    """
    Reconstruct a financial statement from presentation linkbase + fact DataFrame.
    Useful for visual QC and filing cross-checks.
    """
    import pandas as pd
    pres = get_presentation_network(model_xbrl, role_uri)
    target = pd.to_datetime(period_date).date()

    fact_idx = {}
    for _, row in facts_df.iterrows():
        if pd.notna(row['period_date']) and row['period_date'].date() == target:
            fact_idx[row['concept']] = row['numeric_value']

    rows, seen = [], set()
    for arc in pres:
        qn = arc['child_qname']
        if not qn or qn in seen:
            continue
        seen.add(qn)
        local  = qn.split('}')[-1] if '}' in qn else qn
        value  = fact_idx.get(local)
        label  = get_concept_label(model_xbrl, qn)
        indent = '  ' * arc['depth']
        rows.append({
            'depth':  arc['depth'],
            'label':  indent + label,
            'concept': local,
            'value':  value,
            'display': f'{value:>20,.0f}' if value is not None else '',
        })
    return pd.DataFrame(rows)
