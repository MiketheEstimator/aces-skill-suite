## Calculation Validation

```python
def validate_calculations_manual(
    facts_df: 'pd.DataFrame',
    calc_arcs: list[dict],
    tolerance_multiplier: float = 5e-4,
) -> list[dict]:
    """
    Verify calculation linkbase arithmetic without Arelle.
    Implements the XBRL 2.1 spec tolerance formula exactly.

    Tolerance per spec: allowed_delta = max(0.5, |reported| * 5e-4)

    Use case: custom audit trail reports, pre-Arelle sanity checks,
    pipelines that receive instance documents without their DTS.
    """
    from itertools import groupby

    # Build (local_name, context_ref) -> float index
    fact_idx: dict[tuple, float] = {}
    for _, row in facts_df.iterrows():
        if row['numeric_value'] is not None:
            fact_idx[(row['concept'], row['context_ref'])] = row['numeric_value']

    arcs_sorted = sorted(calc_arcs, key=lambda x: (x['parent'], x['role']))
    issues = []

    for (parent_q, role), child_iter in groupby(
        arcs_sorted, key=lambda x: (x['parent'], x['role'])
    ):
        children     = list(child_iter)
        parent_local = parent_q.split('}')[-1] if '}' in parent_q else parent_q
        parent_ctxs  = [ctx for (c, ctx) in fact_idx if c == parent_local]

        for ctx in parent_ctxs:
            reported = fact_idx.get((parent_local, ctx))
            if reported is None:
                continue

            computed, missing = 0.0, []
            for arc in children:
                child_local = arc['child'].split('}')[-1] if '}' in arc['child'] else arc['child']
                child_val   = fact_idx.get((child_local, ctx))
                if child_val is None:
                    missing.append(child_local)
                    continue
                computed += arc['weight'] * child_val

            if missing:
                continue  # Skip: cannot validate with incomplete children

            allowed = max(0.5, abs(reported) * tolerance_multiplier)
            delta   = abs(reported - computed)

            if delta > allowed:
                issues.append({
                    'parent':        parent_local,
                    'context_ref':   ctx,
                    'reported':      reported,
                    'computed':      computed,
                    'delta':         round(delta, 2),
                    'allowed_delta': round(allowed, 2),
                    'role':          role,
                })

    return sorted(issues, key=lambda x: -x['delta'])


def print_calc_report(issues: list[dict]) -> None:
    if not issues:
        print('  Calculation: PASS')
        return
    print(f'  Calculation: FAIL ({len(issues)} inconsistency(ies))')
    for inc in issues[:10]:
        print(f"  ERR: {inc['parent']} [{inc['context_ref']}]")
        print(f"      Reported: {inc['reported']:>20,.0f}")
        print(f"      Computed: {inc['computed']:>20,.0f}")
        print(f"      Delta:    {inc['delta']:>20,.2f}  (allowed: {inc['allowed_delta']:.2f})")
