## Full Validation Pipeline

```python
from pathlib import Path
import json


def run_xbrl_pipeline(
    instance_path:              str | Path,
    output_dir:                 str | Path,
    is_ixbrl:                   bool = False,
    check_edgar_prior_year:     bool = False,
    cik:                        str  = None,
    current_fy:                 int  = None,
    prior_fy:                   int  = None,
) -> dict:
    """
    End-to-end XBRL validation pipeline:
      Stage 1 — Instance document load + XBRL 2.1 validation (Arelle)
      Stage 2 — Calculation linkbase arithmetic check
      Stage 3 — lxml fact extraction -> DataFrame + CSV
      Stage 4 — iXBRL-specific checks (if is_ixbrl)
      Stage 5 — EDGAR prior-year consistency check (if requested)

    Returns structured JSON report with per-stage pass/fail status.
    """
    instance_path = Path(instance_path)
    out = Path(output_dir)
    out.mkdir(parents=True, exist_ok=True)

    report = {
        'instance': str(instance_path),
        'is_ixbrl': is_ixbrl,
        'stages':   {},
        'overall':  'pass',
    }

    # Stage 1 — Arelle validation
    print('[1/5] Instance Validation')
    val = validate_instance(instance_path)
    report['stages']['instance'] = {
        'status':       val['status'],
        'error_count':  val['error_count'],
        'fact_count':   val['fact_count'],
        'errors':       val['errors'][:10],
    }
    if val['status'] == 'fail':
        report['overall'] = 'fail'

    # Stage 2 — Calculation check
    print('[2/5] Calculation Linkbase')
    calc = val.get('calc_issues', [])
    report['stages']['calculations'] = {
        'status':         'pass' if not calc else 'fail',
        'inconsistencies': len(calc),
        'details':         calc[:5],
    }
    if calc:
        report['overall'] = 'fail'
        print_calc_report(calc)

    # Stage 3 — Fact extraction
    print('[3/5] Fact Extraction')
    if not is_ixbrl:
        parsed   = parse_instance_lxml(instance_path)
        facts_df = facts_to_dataframe(parsed)
        csv_path = out / f'{instance_path.stem}_facts.csv'
        facts_df.to_csv(str(csv_path), index=False)
        report['stages']['fact_extraction'] = {
            'status':        'pass',
            'facts':         len(facts_df),
            'contexts':      len(parsed['contexts']),
            'concepts':      facts_df['concept'].nunique(),
            'csv':           str(csv_path),
        }
        print(f'  Facts CSV: {csv_path.name}')

    # Stage 4 — iXBRL checks
    print('[4/5] iXBRL Validation')
    if is_ixbrl:
        ix = validate_ixbrl(instance_path)
        report['stages']['ixbrl'] = ix
        if ix['status'] == 'fail':
            report['overall'] = 'fail'
    else:
        report['stages']['ixbrl'] = {'status': 'skipped'}

    # Stage 5 — EDGAR prior-year comparison
    print('[5/5] EDGAR Consistency')
    if check_edgar_prior_year and cik and current_fy and prior_fy:
        key_concepts = [
            'Revenues', 'NetIncomeLoss', 'Assets',
            'LiabilitiesAndStockholdersEquity', 'OperatingIncomeLoss',
        ]
        try:
            cmp = compare_prior_year(cik, key_concepts, current_fy, prior_fy)
            flagged = cmp[cmp['flag'] != '']
            report['stages']['edgar_consistency'] = {
                'status':           'warning' if len(flagged) else 'pass',
                'concepts_checked': len(key_concepts),
                'flagged':          len(flagged),
                'flags':            flagged.to_dict('records'),
            }
        except Exception as exc:
            report['stages']['edgar_consistency'] = {
                'status': 'error', 'message': str(exc)
            }
    else:
        report['stages']['edgar_consistency'] = {'status': 'skipped'}

    # Write report
    rpt_path = out / f'{instance_path.stem}_report.json'
    rpt_path.write_text(json.dumps(report, indent=2, default=str), encoding='utf-8')
    print(f'\n{'='*55}')
    print(f'OVERALL: {report["overall"].upper()}')
    print(f'Report:  {rpt_path}')
    return report
