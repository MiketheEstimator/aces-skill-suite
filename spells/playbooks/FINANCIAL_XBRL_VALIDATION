## Inline XBRL (iXBRL)

All SEC primary financial statement filings since 2020 must use iXBRL.
iXBRL embeds XBRL tags directly inside human-readable HTML5.

```python
IXBRL_NS = 'http://www.xbrl.org/2013/inlineXBRL'
IXT_NS   = 'http://www.xbrl.org/inlineXBRL/transformation/2020-02-12'
IXT_SEC  = 'http://www.sec.gov/inlineXBRL/transformation/2015-08-31'

IXBRL_ROOT_ATTRS = {
    'xmlns':        IXBRL_NS,
    'xmlns:ix':     IXBRL_NS,
    'xmlns:ixt':    IXT_NS,
    'xmlns:ixt-sec': IXT_SEC,
    'xmlns:xsi':    'http://www.w3.org/2001/XMLSchema-instance',
    'xmlns:us-gaap': 'http://fasb.org/us-gaap/2024',
    'xmlns:dei':    'http://xbrl.sec.gov/dei/2024',
    'xmlns:xbrli':  'http://www.xbrl.org/2003/instance',
    'xmlns:xbrldi': 'http://xbrl.org/2006/xbrldi',
    'xmlns:iso4217': 'http://www.xbrl.org/2003/iso4217',
}


def build_ixbrl_header(
    schema_ref:    str,
    contexts_xml:  list[str],
    units_xml:     list[str],
    hidden_facts:  list[dict],
) -> str:
    """
    Build the ix:header block (placed inside a hidden div at document top).

    hidden_facts: [{'name': 'dei:EntityRegistrantName',
                    'context_ref': 'FY2024', 'value': 'Acme Corp'}]

    All contexts and units referenced anywhere in the document MUST be
    declared inside ix:header/ix:resources. Missing any one = validation error.
    """
    ctx_block = '\n        '.join(contexts_xml)
    unit_block = '\n        '.join(units_xml)
    hidden = '\n'.join(
        f'        <ix:nonNumeric name="{hf["name"]}" contextRef="{hf["context_ref"]}">'
        f'{hf["value"]}</ix:nonNumeric>'
        for hf in hidden_facts
    )
    return (
        '  <div style="display:none">\n'
        '    <ix:header>\n'
        '      <ix:hidden>\n'
        + hidden +
        '\n      </ix:hidden>\n'
        '      <ix:references>\n'
        '        <link:schemaRef\n'
        '          xmlns:link="http://www.xbrl.org/2003/linkbase"\n'
        '          xmlns:xlink="http://www.w3.org/1999/xlink"\n'
        '          xlink:type="simple"\n'
        f'          xlink:href="{schema_ref}"/>\n'
        '      </ix:references>\n'
        '      <ix:resources>\n'
        f'        {ctx_block}\n'
        f'        {unit_block}\n'
        '      </ix:resources>\n'
        '    </ix:header>\n'
        '  </div>'
    )


def ix_nonfraction(
    name:         str,
    context_ref:  str,
    unit_ref:     str,
    decimals:     str,
    display_text: str,
    sign:         str = '',
    fmt:          str = 'ixt:num-dot-decimal',
) -> str:
    """
    Generate an ix:nonFraction tag for a monetary or numeric fact.

    display_text: the formatted number shown to humans (e.g. '391,035')
    sign: use '-' when showing an expense as a positive display value
          but the underlying XBRL value must remain negative.
    fmt: transformation format from the ixt registry (see iXBRL Formats section).

    The tag body is the display value; the transformation format tells
    the XBRL processor how to convert display_text back to the raw value.
    """
    sign_attr = f' sign="{sign}"' if sign else ''
    return (
        f'<ix:nonFraction'
        f' name="{name}"'
        f' contextRef="{context_ref}"'
        f' unitRef="{unit_ref}"'
        f' decimals="{decimals}"'
        f' format="{fmt}"'
        f'{sign_attr}>'
        f'{display_text}'
        f'</ix:nonFraction>'
    )


def ix_nonnumeric(
    name:        str,
    context_ref: str,
    value:       str,
) -> str:
    """ix:nonNumeric tag for string facts (names, codes, descriptions)."""
    return (
        f'<ix:nonNumeric name="{name}" contextRef="{context_ref}">'
        f'{value}'
        f'</ix:nonNumeric>'
    )


def validate_ixbrl(ixbrl_path: str | Path) -> dict:
    """
    Validate iXBRL HTML document with Arelle.
    Checks iXBRL-specific rules beyond standard XBRL 2.1:
    - All tagged facts reference declared contexts
    - All unitRef values declared in ix:header
    - Transformation format values in approved ixt registry
    - No orphaned contexts (declared but unreferenced by any fact)
    """
    cntlr, model_xbrl = load_xbrl_document(ixbrl_path)
    errors, warnings = [], []
    for rec in cntlr.logHandler.logRecordBuffer:
        code  = getattr(rec, 'messageCode', '')
        entry = {'code': code, 'message': rec.getMessage()}
        if rec.levelname.upper() in ('ERROR', 'CRITICAL'):
            errors.append(entry)
        elif rec.levelname.upper() == 'WARNING':
            if 'ix' in code.lower() or 'inline' in code.lower():
                warnings.append(entry)
    used    = {f.contextID for f in model_xbrl.facts}
    orphans = sorted(set(model_xbrl.contexts.keys()) - used)
    if orphans:
        warnings.append({'code': 'ixbrl:orphanContext',
                         'message': f'Unused contexts: {orphans}'})
    model_xbrl.close()
    return {'status': 'pass' if not errors else 'fail',
            'errors': errors, 'warnings': warnings,
            'orphan_contexts': orphans}
