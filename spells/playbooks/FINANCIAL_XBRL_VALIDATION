## EDGAR Package Assembly

```python
import zipfile, shutil, json
from pathlib import Path
from datetime import date


def assemble_edgar_package(
    company_name:     str,
    cik:              str,
    form_type:        str,      # '10-K' | '10-Q' | '8-K'
    period_end:       str,      # '2024-12-31'
    ixbrl_htm:        Path,     # Primary iXBRL-tagged HTML
    extension_schema: Path,     # Company .xsd
    linkbases:        list[Path],  # _cal _def _lab _pre .xml
    r_files:          list[Path],  # R1.htm ... Rn.htm viewer pages
    output_dir:       Path,
    filing_date:      str = None,
) -> Path:
    """
    Assemble and ZIP a complete SEC EDGAR filing package.

    Required contents per EFM Section 6:
    +------------------------------------------+
    | [cik]-[date].htm      Primary iXBRL doc  |
    | [prefix]-[date].xsd   Extension schema   |
    | [prefix]-[date]_cal.xml                  |
    | [prefix]-[date]_def.xml                  |
    | [prefix]-[date]_lab.xml                  |
    | [prefix]-[date]_pre.xml                  |
    | R1.htm ... Rn.htm     XBRL viewer pages  |
    | FilingSummary.xml     Viewer manifest     |
    | header.txt            EDGAR header        |
    +------------------------------------------+
    """
    filing_date = filing_date or date.today().isoformat()
    date_str    = period_end.replace('-', '')
    pkg_dir     = output_dir / f'{cik}_{date_str}_edgar'
    pkg_dir.mkdir(parents=True, exist_ok=True)

    for f in [ixbrl_htm, extension_schema] + linkbases + r_files:
        shutil.copy2(str(f), pkg_dir / f.name)

    _write_filing_summary(pkg_dir, form_type, r_files)
    _write_edgar_header(pkg_dir, cik, company_name, form_type,
                        filing_date, period_end)

    zip_path = output_dir / f'{cik}_{date_str}.zip'
    with zipfile.ZipFile(str(zip_path), 'w', zipfile.ZIP_DEFLATED) as zf:
        for f in pkg_dir.iterdir():
            zf.write(str(f), arcname=f.name)

    size_kb = zip_path.stat().st_size / 1024
    n_files = len(list(pkg_dir.iterdir()))
    print(f'  EDGAR ZIP: {zip_path.name} ({size_kb:.1f} KB, {n_files} files)')
    return zip_path


def _write_filing_summary(pkg_dir: Path, form_type: str,
                            r_files: list[Path]) -> None:
    reports = ''
    for i, rf in enumerate(r_files, start=1):
        is_default = 'true' if i == 1 else 'false'
        reports += (
            f'  <Report instance="{rf.name}">\n'
            f'    <IsDefault>{is_default}</IsDefault>\n'
            f'    <HasEmbeddedReports>false</HasEmbeddedReports>\n'
            f'    <HtmlFileName>{rf.name}</HtmlFileName>\n'
            f'    <LongName>R{i}</LongName>\n'
            f'    <ShortName>R{i}</ShortName>\n'
            f'    <MenuCategory>Statements</MenuCategory>\n'
            f'    <Position>{i}</Position>\n'
            f'  </Report>\n'
        )
    xml = (
        '<?xml version="1.0" encoding="utf-8"?>\n'
        '<FilingSummary>\n'
        '  <Version>3.7.4</Version>\n'
        '  <ReportFormat>htm</ReportFormat>\n'
        '  <HasInlineXBRL>true</HasInlineXBRL>\n'
        f'  <MyReports>\n{reports}  </MyReports>\n'
        f'  <InputFiles><File doctype="{form_type}"/></InputFiles>\n'
        '</FilingSummary>\n'
    )
    (pkg_dir / 'FilingSummary.xml').write_text(xml, encoding='utf-8')


def _write_edgar_header(
    pkg_dir: Path, cik: str, company_name: str,
    form_type: str, filing_date: str, period_end: str,
) -> None:
    fiscal_end = period_end[-5:].replace('-', '')
    hdr = (
        '<SEC-HEADER>\n'
        f'FILING-DATE: {filing_date}\n'
        f'DATE-OF-FILING: {filing_date}\n\n'
        'COMPANY-DATA:\n'
        f' COMPANY-CONFORMED-NAME: {company_name}\n'
        f' CENTRAL-INDEX-KEY: {cik}\n'
        f' FISCAL-YEAR-END: {fiscal_end}\n\n'
        'FILING-VALUES:\n'
        f' FORM-TYPE: {form_type}\n'
        '</SEC-HEADER>\n'
    )
    (pkg_dir / 'header.txt').write_text(hdr, encoding='utf-8')
