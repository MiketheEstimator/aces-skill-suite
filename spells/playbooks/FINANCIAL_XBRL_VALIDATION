## SEC EDGAR API

```python
import requests, time, json
import pandas as pd
from pathlib import Path


EDGAR_BASE    = 'https://data.sec.gov'
EDGAR_HEADERS = {
    # Required by SEC robots.txt — replace with your actual contact info
    'User-Agent':      'YourCompanyName yourname@yourcompany.com',
    'Accept-Encoding': 'gzip, deflate',
}


def get_company_facts(cik: str, cache_dir: Path = None) -> dict:
    """
    Fetch the full XBRL companyfacts JSON for a company.
    Contains every concept ever tagged, every period, every filing.

    CIK must be zero-padded to 10 digits: '0000320193' for Apple.
    Cache locally — re-fetching the same CIK repeatedly wastes quota.
    """
    cik_padded = cik.zfill(10)
    if cache_dir:
        cp = Path(cache_dir) / f'facts_{cik_padded}.json'
        if cp.exists():
            return json.loads(cp.read_text())

    url  = f'{EDGAR_BASE}/api/xbrl/companyfacts/CIK{cik_padded}.json'
    resp = requests.get(url, headers=EDGAR_HEADERS, timeout=30)
    resp.raise_for_status()
    data = resp.json()

    if cache_dir:
        Path(cache_dir).mkdir(parents=True, exist_ok=True)
        (Path(cache_dir) / f'facts_{cik_padded}.json').write_text(
            resp.text, encoding='utf-8'
        )
    return data


def extract_concept_series(
    company_facts: dict,
    concept:       str,
    taxonomy:      str = 'us-gaap',
    unit:          str = 'USD',
    forms:         list[str] = None,
) -> pd.DataFrame:
    """
    Extract historical time series for one XBRL concept.
    concept: 'Revenues', 'NetIncomeLoss', 'Assets', 'EarningsPerShareBasic', ...
    unit:    'USD' | 'USD/shares' | 'shares' | 'pure'
    forms:   filter to form types, e.g. ['10-K', '10-K/A']. None = all.

    Deduplicates by period end: keeps the most recent filing per period.
    """
    try:
        raw = company_facts['facts'][taxonomy][concept]['units'][unit]
    except KeyError:
        return pd.DataFrame(columns=['end','val','accn','fy','fp','form','filed'])

    df = pd.DataFrame(raw)
    df['end']   = pd.to_datetime(df['end'],   errors='coerce')
    df['filed'] = pd.to_datetime(df['filed'], errors='coerce')

    if forms:
        df = df[df['form'].isin(forms)]

    df = (df.sort_values('filed')
            .drop_duplicates(subset=['end'], keep='last')
            .sort_values('end')
            .reset_index(drop=True))
    return df[['end','val','accn','fy','fp','form','filed']]


def build_financial_timeseries(
    cik:       str,
    concepts:  list[str],
    taxonomy:  str = 'us-gaap',
    forms:     list[str] = None,
    cache_dir: Path = None,
) -> pd.DataFrame:
    """
    Wide-format financial time series: rows = period dates, columns = concepts.
    """
    facts  = get_company_facts(cik, cache_dir)
    forms  = forms or ['10-K', '10-K/A']
    series = {}
    for concept in concepts:
        df = extract_concept_series(facts, concept, taxonomy, forms=forms)
        if not df.empty:
            series[concept] = df.set_index('end')['val']
    if not series:
        return pd.DataFrame()
    out = pd.DataFrame(series)
    out.index.name = 'period_end'
    return out


def compare_prior_year(
    cik:               str,
    concepts:          list[str],
    current_fy:        int,
    prior_fy:          int,
    flag_threshold_pct: float = 25.0,
) -> pd.DataFrame:
    """
    Compare key XBRL metrics between current and prior fiscal year.
    Flags concepts with YoY change > flag_threshold_pct.
    Use as pre-submission QC: large moves may indicate element mapping errors.
    """
    facts = get_company_facts(cik)
    rows  = []

    for concept in concepts:
        df = extract_concept_series(facts, concept, forms=['10-K', '10-K/A'])
        if df.empty:
            continue
        cy = df[df['fy'] == current_fy]['val'].values
        py = df[df['fy'] == prior_fy]['val'].values
        cv = float(cy[0]) if len(cy) else None
        pv = float(py[0]) if len(py) else None

        pct = ((cv - pv) / abs(pv) * 100
               if cv is not None and pv and pv != 0 else None)

        def fmt(v):
            if v is None: return 'N/A'
            if abs(v) >= 1e9: return f'${v/1e9:.2f}B'
            if abs(v) >= 1e6: return f'${v/1e6:.1f}M'
            return f'{v:,.0f}'

        rows.append({
            'concept':         concept,
            f'FY{current_fy}': fmt(cv),
            f'FY{prior_fy}':   fmt(pv),
            'YoY_pct':         f'{pct:+.1f}%' if pct is not None else 'N/A',
            'flag':            'REVIEW' if pct and abs(pct) > flag_threshold_pct else '',
        })

    return pd.DataFrame(rows)
