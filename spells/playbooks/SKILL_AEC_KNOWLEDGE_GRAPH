## Neo4j Implementation

Neo4j is the right choice for: persistent multi-session graphs, concurrent readers,
large projects (10,000+ nodes), or when Cypher queries are more natural than Python
traversals.

### Connection and Schema Setup

```python
from neo4j import GraphDatabase
from contextlib import contextmanager

class AECNeo4jGraph:
    """
    Neo4j-backed AEC Knowledge Graph.
    Uses the official neo4j Python driver.
    """

    def __init__(self, uri: str, user: str, password: str,
                  project_id: str):
        self.project_id = project_id
        self._driver = GraphDatabase.driver(uri, auth=(user, password))

    def close(self):
        self._driver.close()

    @contextmanager
    def session(self):
        with self._driver.session() as s:
            yield s

    def create_schema_constraints(self):
        """Idempotent — run once per database/project."""
        constraints = [
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:Document)   REQUIRE n.doc_id IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:ScopeItem)  REQUIRE n.item_id IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:RFI)        REQUIRE n.rfi_number IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:Submittal)  REQUIRE n.submittal_number IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:Trade)      REQUIRE n.name IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:SpecSection)REQUIRE n.section_number IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:Drawing)    REQUIRE n.drawing_number IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:Zone)       REQUIRE n.zone_id IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:GISFeature) REQUIRE n.feature_id IS UNIQUE",
            "CREATE CONSTRAINT IF NOT EXISTS FOR (n:Conflict)   REQUIRE n.conflict_id IS UNIQUE",
        ]
        with self.session() as s:
            for c in constraints:
                s.run(c)
        print("Schema constraints applied")

    # ── Node upsert helpers ───────────────────────────────────────────────────

    def merge_scope_item(self, item_id: str, trade: str,
                          description: str, csi_division: str,
                          condition_class: str, evidence_status: str,
                          cost_ability: str, **kwargs) -> None:
        props = {
            "item_id": item_id, "trade": trade,
            "description": description, "csi_division": csi_division,
            "condition_class": condition_class,
            "evidence_status": evidence_status,
            "cost_ability": cost_ability,
            "project_id": self.project_id,
            **kwargs
        }
        with self.session() as s:
            s.run("""
                MERGE (n:ScopeItem {item_id: $item_id})
                SET n += $props
            """, item_id=item_id, props=props)

    def merge_rfi(self, rfi_number: str, priority: str, subject: str,
                   discipline: str, status: str, response_due: str,
                   **kwargs) -> None:
        props = {
            "rfi_number": rfi_number, "priority": priority,
            "subject": subject, "discipline": discipline,
            "status": status, "response_due": response_due,
            "project_id": self.project_id, **kwargs
        }
        with self.session() as s:
            s.run("""
                MERGE (n:RFI {rfi_number: $rfi_number})
                SET n += $props
            """, rfi_number=rfi_number, props=props)

    # ── Edge upsert helpers ───────────────────────────────────────────────────

    def merge_blocks(self, rfi_number: str, item_id: str,
                      priority: str = "") -> None:
        """RFI BLOCKS ScopeItem."""
        with self.session() as s:
            s.run("""
                MATCH (r:RFI {rfi_number: $rfi_number})
                MATCH (s:ScopeItem {item_id: $item_id})
                MERGE (r)-[e:BLOCKS]->(s)
                SET e.priority = $priority
            """, rfi_number=rfi_number, item_id=item_id, priority=priority)

    def merge_extracted_from(self, item_id: str, doc_id: str,
                              confidence: float = 1.0,
                              anchor_text: str = "") -> None:
        with self.session() as s:
            s.run("""
                MATCH (s:ScopeItem {item_id: $item_id})
                MATCH (d:Document  {doc_id:  $doc_id})
                MERGE (s)-[e:EXTRACTED_FROM]->(d)
                SET e.confidence = $confidence,
                    e.anchor_text = $anchor_text
            """, item_id=item_id, doc_id=doc_id,
                 confidence=confidence, anchor_text=anchor_text)

    def merge_supersedes(self, newer_doc_id: str,
                          older_doc_id: str, issue_date: str = "") -> None:
        with self.session() as s:
            s.run("""
                MATCH (a:Document {doc_id: $newer})
                MATCH (b:Document {doc_id: $older})
                MERGE (a)-[e:SUPERSEDES]->(b)
                SET e.issue_date = $issue_date
            """, newer=newer_doc_id, older=older_doc_id,
                 issue_date=issue_date)
```

### Cypher Query Reference

```cypher
// ── Node lookups ──────────────────────────────────────────────────────────────

// All FATAL open RFIs
MATCH (r:RFI {priority: "FATAL", status: "ISSUED"})
RETURN r.rfi_number, r.subject, r.response_due
ORDER BY r.response_due;

// All scope items that are NOT_COSTABLE
MATCH (s:ScopeItem {cost_ability: "NOT_COSTABLE"})
RETURN s.item_id, s.trade, s.description;


// ── Single-hop traversals ─────────────────────────────────────────────────────

// All scope items blocked by a specific RFI
MATCH (r:RFI {rfi_number: "RFI-017"})-[:BLOCKS]->(s:ScopeItem)
RETURN s.item_id, s.description, s.trade;

// Which documents does a scope item trace back to?
MATCH (s:ScopeItem {item_id: "STRUCT-042"})-[:EXTRACTED_FROM]->(d:Document)
RETURN d.doc_id, d.family, d.title, d.status;

// All drawings referenced by Structural scope items
MATCH (s:ScopeItem)-[:BELONGS_TO]->(:Trade {name: "Structural"}),
      (s)-[:REFERENCES]->(dw:Drawing)
RETURN DISTINCT dw.drawing_number, dw.title
ORDER BY dw.drawing_number;


// ── Multi-hop traversals ──────────────────────────────────────────────────────

// Which trades are blocked by open FATAL RFIs
// whose source documents have been superseded?
MATCH (r:RFI {priority: "FATAL", status: "ISSUED"})-[:BLOCKS]->(s:ScopeItem)
      -[:EXTRACTED_FROM]->(d:Document)<-[:SUPERSEDES]-(:Document)
MATCH (s)-[:BELONGS_TO]->(t:Trade)
RETURN DISTINCT t.name AS trade,
       COUNT(DISTINCT s) AS blocked_scope_items,
       COUNT(DISTINCT r) AS blocking_rfis
ORDER BY blocked_scope_items DESC;

// What scope items share a drawing with a contradictory scope item?
MATCH (s1:ScopeItem {evidence_status: "CONTRADICTORY"})
      -[:REFERENCES]->(dw:Drawing)<-[:REFERENCES]-(s2:ScopeItem)
WHERE s1.item_id <> s2.item_id
RETURN s1.item_id AS problem_item,
       dw.drawing_number AS shared_drawing,
       s2.item_id AS related_item,
       s2.evidence_status;

// Full impact chain: Conflict → RFI → blocked ScopeItems → Trade → Submittals still pending
MATCH (c:Conflict)<-[:GENERATED_BY]-(r:RFI)-[:BLOCKS]->(s:ScopeItem)
      -[:BELONGS_TO]->(t:Trade)
MATCH (spec:SpecSection)-[:REQUIRES]->(sub:Submittal {disposition: "REVISE_AND_RESUBMIT"})
MATCH (s)-[:GOVERNED_BY]->(spec)
RETURN c.conflict_id, r.rfi_number, s.item_id, t.name,
       spec.section_number, sub.submittal_number
ORDER BY c.conflict_id;


// ── Path queries ──────────────────────────────────────────────────────────────

// Shortest path between a scope item and a GIS feature
MATCH path = shortestPath(
  (s:ScopeItem {item_id: "CIVIL-008"})-[*]-(g:GISFeature {feature_id: "UTIL-CORRIDOR-01"})
)
RETURN [n IN nodes(path) | n.node_id] AS path_nodes,
       length(path) AS hops;

// All scope items reachable from a superseded document (impact of doc retirement)
MATCH (superseded:Document {doc_id: "SPEC-V1"})
      <-[:SUPERSEDES*1..3]-(:Document)
MATCH (s:ScopeItem)-[:EXTRACTED_FROM]->(superseded)
RETURN s.item_id, s.description, s.evidence_status;


// ── Aggregations ──────────────────────────────────────────────────────────────

// Scope item count by trade × evidence_status (heat map input)
MATCH (s:ScopeItem)-[:BELONGS_TO]->(t:Trade)
RETURN t.name AS trade, s.evidence_status, COUNT(s) AS count
ORDER BY trade, s.evidence_status;

// Overdue RFI count per discipline
MATCH (r:RFI {status: "OVERDUE"})
RETURN r.discipline, COUNT(r) AS overdue_count
ORDER BY overdue_count DESC;

// Submittal compliance: approved vs pending per spec section
MATCH (spec:SpecSection)-[:REQUIRES]->(sub:Submittal)
RETURN spec.section_number,
       COUNT(sub) AS total,
       SUM(CASE WHEN sub.disposition IN ["APPROVED","APPROVED_AS_NOTED"] THEN 1 ELSE 0 END) AS approved,
       SUM(CASE WHEN sub.disposition NOT IN ["APPROVED","APPROVED_AS_NOTED"] THEN 1 ELSE 0 END) AS pending;
