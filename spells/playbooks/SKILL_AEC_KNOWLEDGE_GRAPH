        "Conflict":    "#BAB0AC",
    }

    pos = nx.spring_layout(G, seed=42, k=2.0)

    # Edges
    edge_x, edge_y = [], []
    for u, v in G.edges():
        x0, y0 = pos[u]
        x1, y1 = pos[v]
        edge_x += [x0, x1, None]
        edge_y += [y0, y1, None]

