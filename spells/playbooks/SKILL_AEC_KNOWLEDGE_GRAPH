## Validation & QA

```python
def validate_aec_kg(kg: AECKnowledgeGraph) -> dict:
    """
    Full validation of AEC-KG structural and domain integrity.
    Returns a report with FATAL, WARNING, and INFO items.
    """
    fatals, warnings, infos = [], [], []
    G = kg.G

    # ── Required node fields ──────────────────────────────────────────────────
    REQUIRED_FIELDS = {
        "Document":   ["doc_id", "family", "title"],
        "ScopeItem":  ["item_id", "trade", "description",
                       "evidence_status", "cost_ability"],
        "RFI":        ["rfi_number", "priority", "status",
                       "subject", "response_due"],
        "Submittal":  ["submittal_number", "spec_section",
                       "submittal_type", "disposition"],
    }
    for nid, data in G.nodes(data=True):
        ntype = data.get("node_type", "")
        required = REQUIRED_FIELDS.get(ntype, [])
        for field in required:
            if not data.get(field):
                warnings.append(f"Missing '{field}' on {nid}")

    # ── Orphan nodes — no edges at all ────────────────────────────────────────
    for nid in G.nodes:
        if G.degree(nid) == 0:
            ntype = G.nodes[nid].get("node_type", "?")
            if ntype not in ("Trade", "Zone", "Organization"):  # expected singletons
                warnings.append(f"Orphan node (no edges): {nid}")

    # ── Scope items with no source document ───────────────────────────────────
    for scope in kg.nodes_of_type("ScopeItem"):
        scope_nid = f"SCOPE:{scope['item_id']}"
        docs = [
            v for _, v, d in G.out_edges(scope_nid, data=True)
            if d.get("rel_type") == "EXTRACTED_FROM"
        ]
        if not docs:
            fatals.append(f"ScopeItem has no EXTRACTED_FROM edge: {scope['item_id']}")

    # ── Scope items with no trade ─────────────────────────────────────────────
    for scope in kg.nodes_of_type("ScopeItem"):
        scope_nid = f"SCOPE:{scope['item_id']}"
        trades = [
            v for _, v, d in G.out_edges(scope_nid, data=True)
            if d.get("rel_type") == "BELONGS_TO"
        ]
        if not trades:
            warnings.append(f"ScopeItem has no BELONGS_TO trade: {scope['item_id']}")

    # ── FATAL RFIs with no blocked scope items ────────────────────────────────
    for rfi in kg.nodes_of_type("RFI"):
        if rfi.get("priority") == "FATAL":
            rfi_nid = f"RFI:{rfi['rfi_number']}"
            blocked = [
                v for _, v, d in G.out_edges(rfi_nid, data=True)
                if d.get("rel_type") == "BLOCKS"
            ]
            if not blocked:
                warnings.append(
                    f"FATAL RFI has no BLOCKS edges: {rfi['rfi_number']} — "
                    f"cannot compute trade impact"
                )

    # ── Conflict nodes with no RFI ────────────────────────────────────────────
    for conflict in kg.nodes_of_type("Conflict"):
        conflict_nid = f"CONFLICT:{conflict['conflict_id']}"
        rfis = list(G.predecessors(conflict_nid))
        if not rfis:
            infos.append(
                f"Conflict has no linked RFI: {conflict['conflict_id']}"
            )

    # ── Edges with unknown rel_type ───────────────────────────────────────────
    KNOWN_REL_TYPES = {
        "EXTRACTED_FROM", "CONTRADICTS", "SUPERSEDES", "REFERENCES",
        "GOVERNED_BY", "BELONGS_TO", "BLOCKS", "GENERATED_BY",
        "REQUIRES", "COVERS", "ISSUED_BY", "ISSUED_TO", "EMPLOYED_BY",
        "LOCATED_IN", "CORRESPONDS_TO", "ANSWERS", "DEPENDS_ON",
    }
    for u, v, data in G.edges(data=True):
        rt = data.get("rel_type", "")
        if rt not in KNOWN_REL_TYPES:
            warnings.append(f"Unknown rel_type '{rt}' on edge {u} → {v}")

    # ── Summary ───────────────────────────────────────────────────────────────
    verdict = "FAIL" if fatals else ("WARN" if warnings else "PASS")
    print(f"\nAEC-KG Validation — Project {kg.project_id}")
    print(f"  Nodes: {G.number_of_nodes()}  Edges: {G.number_of_edges()}")
    print(f"  Verdict: {verdict}")
    for f in fatals:   print(f"  FATAL:   {f}")
    for w in warnings: print(f"  WARNING: {w}")
    for i in infos:    print(f"  INFO:    {i}")

    return {"pass": not fatals, "fatals": fatals,
            "warnings": warnings, "infos": infos}
```

### QA Checklist

- [ ] Every `ScopeItem` has at least one `EXTRACTED_FROM` edge to a `Document`
- [ ] Every `ScopeItem` has exactly one `BELONGS_TO` edge to a `Trade`
- [ ] Every `RFI` node with `priority=FATAL` has at least one `BLOCKS` edge
- [ ] Every `Conflict` node is connected to at least one `RFI` via `GENERATED_BY`
- [ ] No orphan nodes (degree 0) except expected singletons (Trade, Zone)
- [ ] All node IDs follow `{TYPE_PREFIX}:{KEY}` convention
- [ ] `validate_aec_kg()` returns `FAIL=False` before any export or analysis
- [ ] JSON snapshot is written after each pipeline run and committed to version control
- [ ] GraphML export opens in Gephi without errors
- [ ] RDF Turtle export validates with `rapper -i turtle` or `rdflib.parse()`
- [ ] Multi-hop queries return non-empty results on a populated graph (smoke test)
- [ ] `compute_rfi_risk_scores()` returns same count as open RFI count in log

