## Subgraph Extraction

Extract a focused subgraph for a single trade, discipline, zone, or document family.

```python
def extract_trade_subgraph(kg: AECKnowledgeGraph,
                            trade_name: str) -> nx.MultiDiGraph:
    """
    Extract all nodes and edges relevant to a single trade.
    Includes: trade's scope items, their source docs, RFIs blocking them,
    spec sections, drawings, and submittals.
    """
    # Seed: scope items belonging to trade
    trade_nid    = f"TRADE:{trade_name}"
    scope_nids   = set(kg.G.predecessors(trade_nid))

    # Expand to all neighbors within 2 hops
    relevant = set(scope_nids) | {trade_nid}
    for scope_nid in scope_nids:
        relevant.update(kg.G.successors(scope_nid))     # docs, spec, drawing
        relevant.update(kg.G.predecessors(scope_nid))   # RFIs blocking this scope

    # Build subgraph
    sub = kg.G.subgraph(relevant).copy()
    sub.graph["trade_filter"] = trade_name
    sub.graph["extracted_at"] = datetime.utcnow().isoformat()
    return sub


def extract_zone_subgraph(kg: AECKnowledgeGraph,
                           zone_id: str) -> nx.MultiDiGraph:
    """All scope items and their dependencies within a spatial zone."""
    zone_nid   = f"ZONE:{zone_id}"
    scope_nids = set(kg.G.predecessors(zone_nid))
    relevant   = set(scope_nids) | {zone_nid}
    for s in scope_nids:
        relevant.update(kg.G.successors(s))
        relevant.update(kg.G.predecessors(s))
    return kg.G.subgraph(relevant).copy()


def extract_rfi_neighbourhood(kg: AECKnowledgeGraph,
                               rfi_number: str,
                               hops: int = 2) -> nx.MultiDiGraph:
    """
    BFS neighbourhood around an RFI node up to `hops` edges.
    Useful for presenting context when reviewing a single RFI.
    """
    rfi_nid = f"RFI:{rfi_number}"
    reachable = {rfi_nid}
    frontier  = {rfi_nid}
    for _ in range(hops):
        next_frontier = set()
        for nid in frontier:
            next_frontier.update(kg.G.successors(nid))
            next_frontier.update(kg.G.predecessors(nid))
        next_frontier -= reachable
        reachable |= next_frontier
        frontier   = next_frontier
    return kg.G.subgraph(reachable).copy()
