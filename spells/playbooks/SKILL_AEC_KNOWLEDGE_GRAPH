## Graph Metrics

```python
def compute_graph_metrics(kg: AECKnowledgeGraph) -> dict:
    """
    Compute centrality and connectivity metrics that identify
    the highest-impact nodes in the AEC-KG.
    """
    G = kg.G
    undirected = G.to_undirected()

    # Degree centrality — most connected nodes
    degree_cent = nx.degree_centrality(undirected)
    top_degree  = sorted(degree_cent.items(), key=lambda x: x[1], reverse=True)[:10]

    # Betweenness centrality — nodes on most shortest paths (bottlenecks)
    # WARNING: O(n³) for large graphs — sample if >5000 nodes
    if G.number_of_nodes() < 5000:
        between_cent = nx.betweenness_centrality(undirected, normalized=True)
        top_between  = sorted(between_cent.items(), key=lambda x: x[1], reverse=True)[:10]
    else:
        # Approximate with k samples
        between_cent = nx.betweenness_centrality(undirected, k=500, normalized=True)
        top_between  = sorted(between_cent.items(), key=lambda x: x[1], reverse=True)[:10]

    # In-degree centrality for directed graph — what nodes are most depended upon?
    in_degree_cent = nx.in_degree_centrality(G)
    top_in_degree  = sorted(in_degree_cent.items(), key=lambda x: x[1], reverse=True)[:10]

    # Strongly connected components
    sccs = list(nx.strongly_connected_components(G))

    # Weakly connected components (isolated subgraphs)
    wccs = list(nx.weakly_connected_components(G))

    # Annotate top nodes with labels for readability
    def label(nid):
        data = G.nodes.get(nid, {})
        return f"{data.get('node_type','?')}:{nid}"

    return {
        "total_nodes": G.number_of_nodes(),
        "total_edges": G.number_of_edges(),
        "top_degree_centrality":      [(label(n), round(v, 4)) for n, v in top_degree],
        "top_betweenness_centrality": [(label(n), round(v, 4)) for n, v in top_between],
        "top_in_degree_centrality":   [(label(n), round(v, 4)) for n, v in top_in_degree],
        "strongly_connected_components": len(sccs),
        "weakly_connected_components":   len(wccs),
        "largest_wcc_size":              max(len(c) for c in wccs) if wccs else 0,
        "isolated_nodes": [
            label(n) for n in G.nodes
            if G.degree(n) == 0
        ],
    }
