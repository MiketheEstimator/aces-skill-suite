```python
def compute_rfi_risk_scores(kg: AECKnowledgeGraph) -> list[dict]:
    """
    Score each open RFI by: priority weight × blocked scope count
    × source document supersession status × days overdue.
    High scores = highest risk items to surface in dashboards.
    """
    from datetime import date
    PRIORITY_WEIGHT = {"FATAL": 10, "HIGH": 5, "ADVISORY": 1}
    today = date.today()
    superseded_docs = {
        v for _, v, d in kg.edges_of_type("SUPERSEDES")
    }

    results = []
    for rfi in kg.nodes_of_type("RFI"):
        if rfi.get("status") in ("CLOSED_ANSWERED", "CLOSED_VOID",
                                  "CLOSED_SUPERSEDED"):
            continue

        rfi_nid = f"RFI:{rfi['rfi_number']}"
        blocked = list(kg.G.successors(rfi_nid))
        n_blocked = sum(
            1 for b in blocked
            if kg.G.nodes[b].get("node_type") == "ScopeItem"
        )

        # Check superseded sources
        superseded_source = False
        for scope_nid in blocked:
            for doc_nid in kg.G.successors(scope_nid):
                if doc_nid in superseded_docs:
                    superseded_source = True
                    break

        # Days overdue
        due_str = rfi.get("response_due", "")
        days_overdue = 0
        if due_str:
            try:
                due = date.fromisoformat(due_str)
                days_overdue = max(0, (today - due).days)
            except ValueError:
                pass

        pw = PRIORITY_WEIGHT.get(rfi.get("priority", "ADVISORY"), 1)
        score = (
            pw
            * max(1, n_blocked)
            * (2 if superseded_source else 1)
            * (1 + days_overdue / 10)
        )

        results.append({
            "rfi_number":        rfi["rfi_number"],
            "priority":          rfi.get("priority"),
            "subject":           rfi.get("subject"),
            "blocked_items":     n_blocked,
            "superseded_source": superseded_source,
            "days_overdue":      days_overdue,
            "risk_score":        round(score, 2),
        })

    return sorted(results, key=lambda x: x["risk_score"], reverse=True)


def submittal_compliance_by_trade(kg: AECKnowledgeGraph) -> list[dict]:
    """
    For each trade: how many required submittals are approved vs pending?
    Joins: Trade ← ScopeItem → SpecSection → Submittal.
    """
    from collections import defaultdict
    trade_subs = defaultdict(lambda: {"approved": set(), "pending": set()})

    for scope in kg.nodes_of_type("ScopeItem"):
        scope_nid = f"SCOPE:{scope['item_id']}"
        trades = kg.neighbors_of_type(scope_nid, rel_type="BELONGS_TO",
                                       node_type="Trade")
        trade_name = trades[0]["name"] if trades else "Unassigned"

        specs = kg.neighbors_of_type(scope_nid, rel_type="GOVERNED_BY",
                                      node_type="SpecSection")
        for spec in specs:
            spec_nid = f"SPEC:{spec['section_number'].replace(' ','.')}"
            subs = kg.neighbors_of_type(spec_nid, rel_type="REQUIRES",
                                         node_type="Submittal")
            for sub in subs:
                sub_num = sub["submittal_number"]
                if sub.get("disposition") in ("APPROVED", "APPROVED_AS_NOTED"):
                    trade_subs[trade_name]["approved"].add(sub_num)
                else:
                    trade_subs[trade_name]["pending"].add(sub_num)

    rows = []
    for trade, buckets in sorted(trade_subs.items()):
        approved = len(buckets["approved"])
        pending  = len(buckets["pending"])
        total    = approved + pending
        rows.append({
            "trade":       trade,
            "approved":    approved,
            "pending":     pending,
            "total":       total,
            "pct_approved": round(approved / total * 100, 1) if total else 100,
        })
    return rows
