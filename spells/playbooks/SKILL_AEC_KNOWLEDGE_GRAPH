### Multi-hop Reasoning Patterns (NetworkX)

```python
from collections import defaultdict

# ── Pattern 1: Trades blocked by FATAL RFIs from superseded documents ────────

def blocked_trades_from_superseded_sources(kg: AECKnowledgeGraph) -> list[dict]:
    """
    Multi-hop: FATAL RFI → blocked ScopeItems → source Documents
    → check if Document is target of a SUPERSEDES edge → aggregate by Trade.
    """
    superseded_docs = {
        v for u, v, d in kg.edges_of_type("SUPERSEDES")
    }

    fatal_rfis = [
        n for n in kg.nodes_of_type("RFI")
        if n.get("priority") == "FATAL"
        and n.get("status") in ("ISSUED", "UNDER_REVIEW", "OVERDUE")
    ]

    results = defaultdict(lambda: {"trade": "", "blocked_items": [],
                                    "blocking_rfis": [], "superseded_sources": []})
    for rfi in fatal_rfis:
        rfi_nid = f"RFI:{rfi['rfi_number']}"
        # Scope items blocked by this RFI
        for scope in kg.neighbors_of_type(rfi_nid, rel_type="BLOCKS",
                                           node_type="ScopeItem"):
            scope_nid = f"SCOPE:{scope['item_id']}"
            # Source documents for this scope item
            for doc in kg.neighbors_of_type(scope_nid, rel_type="EXTRACTED_FROM",
                                             node_type="Document"):
                doc_nid = f"DOC:{doc['doc_id']}"
                if doc_nid in superseded_docs:
                    # Find trade
                    trades = kg.neighbors_of_type(scope_nid, rel_type="BELONGS_TO",
                                                   node_type="Trade")
                    trade_name = trades[0]["name"] if trades else "Unassigned"
                    r = results[trade_name]
                    r["trade"] = trade_name
                    if scope["item_id"] not in r["blocked_items"]:
                        r["blocked_items"].append(scope["item_id"])
                    if rfi["rfi_number"] not in r["blocking_rfis"]:
                        r["blocking_rfis"].append(rfi["rfi_number"])
                    if doc["doc_id"] not in r["superseded_sources"]:
                        r["superseded_sources"].append(doc["doc_id"])

    return sorted(results.values(),
                  key=lambda x: len(x["blocked_items"]), reverse=True)


# ── Pattern 2: Scope items sharing drawings with contradictory items ──────────

def scope_sharing_drawings_with_contradictory(kg: AECKnowledgeGraph) -> list[dict]:
    """
    Find scope items that reference the same drawing as a contradictory item.
    Surface potential contagion zones.
    """
    contradictory_items = {
        n["item_id"]
        for n in kg.nodes_of_type("ScopeItem")
        if n.get("evidence_status") == "CONTRADICTORY"
    }

    result = []
    for item_id in contradictory_items:
        item_nid = f"SCOPE:{item_id}"
        # Drawings referenced by this contradictory item
        drawings = kg.neighbors_of_type(item_nid, rel_type="REFERENCES",
                                         node_type="Drawing")
        for dwg in drawings:
            dwg_nid = f"DWG:{dwg['drawing_number']}"
            # Other scope items referencing same drawing
            for other in kg.G.predecessors(dwg_nid):
                if other == item_nid:
                    continue
                other_data = kg.G.nodes[other]
                if other_data.get("node_type") == "ScopeItem":
                    result.append({
                        "contradictory_item":   item_id,
                        "shared_drawing":       dwg["drawing_number"],
                        "potentially_affected":  other_data["item_id"],
                        "affected_status":      other_data.get("evidence_status"),
                        "affected_trade":       other_data.get("trade"),
                    })
    return result


# ── Pattern 3: Full impact chain from a conflict ──────────────────────────────

def conflict_impact_chain(kg: AECKnowledgeGraph,
                           conflict_id: str) -> dict:
    """
    Starting from a Conflict node, trace:
    Conflict → RFI → blocked ScopeItems → Trades → pending Submittals
    """
    conflict_nid = f"CONFLICT:{conflict_id}"
    if conflict_nid not in kg.G:
        raise KeyError(f"Conflict not found: {conflict_id}")

    chain = {
        "conflict_id": conflict_id,
        "rfis":        [],
        "blocked_scope": [],
        "affected_trades": [],
        "pending_submittals": [],
    }

    # RFIs generated by this conflict
    rfis = kg.neighbors_of_type(conflict_nid, rel_type="GENERATED_BY",
                                  node_type="RFI", direction="in")
    for rfi in rfis:
        chain["rfis"].append(rfi["rfi_number"])
        rfi_nid = f"RFI:{rfi['rfi_number']}"

        # Scope items blocked
        for scope in kg.neighbors_of_type(rfi_nid, rel_type="BLOCKS",
                                           node_type="ScopeItem"):
            chain["blocked_scope"].append(scope["item_id"])
            scope_nid = f"SCOPE:{scope['item_id']}"

            # Trade
            for trade in kg.neighbors_of_type(scope_nid, rel_type="BELONGS_TO",
                                               node_type="Trade"):
                if trade["name"] not in chain["affected_trades"]:
                    chain["affected_trades"].append(trade["name"])

            # Spec sections → pending submittals
            for spec in kg.neighbors_of_type(scope_nid, rel_type="GOVERNED_BY",
                                              node_type="SpecSection"):
                spec_nid = f"SPEC:{spec['section_number'].replace(' ','.')}"
                for sub in kg.neighbors_of_type(spec_nid, rel_type="REQUIRES",
                                                 node_type="Submittal"):
                    if sub.get("disposition") not in ("APPROVED", "APPROVED_AS_NOTED"):
                        if sub["submittal_number"] not in chain["pending_submittals"]:
                            chain["pending_submittals"].append(sub["submittal_number"])
    return chain


# ── Pattern 4: Costability report by trade ────────────────────────────────────

def costability_report(kg: AECKnowledgeGraph) -> list[dict]:
    """
    Summarize scope item costability breakdown per trade.
    Output usable directly as dashboard table data.
    """
    from collections import Counter
    trade_buckets: dict[str, Counter] = defaultdict(Counter)

    for scope in kg.nodes_of_type("ScopeItem"):
        scope_nid = f"SCOPE:{scope['item_id']}"
        trades = kg.neighbors_of_type(scope_nid, rel_type="BELONGS_TO",
                                       node_type="Trade")
        trade_name = trades[0]["name"] if trades else "Unassigned"
        trade_buckets[trade_name][scope.get("cost_ability", "NOT_COSTABLE")] += 1

    rows = []
    for trade, counts in sorted(trade_buckets.items()):
        total = sum(counts.values())
        rows.append({
            "trade":         trade,
            "total":         total,
            "costable":      counts.get("COSTABLE", 0),
            "partial":       counts.get("PARTIAL", 0),
            "not_costable":  counts.get("NOT_COSTABLE", 0),
            "not_scope":     counts.get("NOT_SCOPE", 0),
            "pct_costable":  round(counts.get("COSTABLE", 0) / total * 100, 1)
                             if total else 0,
        })
    return rows
