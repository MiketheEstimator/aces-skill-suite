import json
from pathlib import Path
from datetime import date, datetime

def populate_from_pipeline_registers(
    kg: AECKnowledgeGraph,
    corpus_registry_path: str,
    scope_baseline_path:  str,
    rfi_log_path:         str,
    submittal_log_path:   str,
) -> dict:
    """
    Populate the AEC-KG from the four canonical pipeline outputs.
    Returns a population report.
    """
    report = {
        "documents": 0, "scope_items": 0,
        "rfis": 0,       "submittals": 0,
        "edges": 0,      "errors": [],
    }

    # ── 1. Corpus Registry → Document nodes ──────────────────────────────────
    corpus_path = Path(corpus_registry_path)
    if corpus_path.exists():
        with open(corpus_path) as f:
            corpus = json.load(f)
        for doc in corpus.get("documents", []):
            kg.add_document(
                doc_id     = doc["identifier"],
                family     = doc["family_code"],
                title      = doc.get("title", ""),
                issue_date = doc.get("issue_date", ""),
                status     = doc.get("status", "CURRENT"),
                file_path  = doc.get("file_path", ""),
            )
            report["documents"] += 1
        # Supersession edges from corpus
        for sup in corpus.get("supersessions", []):
            try:
                kg.link_supersession(
                    newer_doc_id = sup["newer"],
                    older_doc_id = sup["older"],
                    issue_date   = sup.get("issue_date", ""),
                )
                report["edges"] += 1
            except KeyError as e:
                report["errors"].append(f"Supersession edge: {e}")

    # ── 2. Scope Baseline → ScopeItem + Trade + Spec + Drawing nodes/edges ───
    scope_path = Path(scope_baseline_path)
    if scope_path.exists():
        with open(scope_path) as f:
            baseline = json.load(f)
        for item in baseline.get("scope_items", []):
            # Ensure trade node exists
            kg.add_trade(item.get("trade", "Unassigned"))
            # Scope item node
            kg.add_scope_item(
                item_id        = item["item_id"],
                trade          = item.get("trade", "Unassigned"),
                description    = item.get("description", ""),
                csi_division   = item.get("csi_division", ""),
                condition_class= item.get("condition_class", ""),
                evidence_status= item.get("evidence_status", "UNDEFINED"),
                cost_ability   = item.get("cost_ability", "NOT_COSTABLE"),
                quantity       = item.get("quantity"),
                unit           = item.get("unit", ""),
            )
            report["scope_items"] += 1

            # Edges: BELONGS_TO trade
            try:
                kg.link_scope_to_trade(item["item_id"], item.get("trade", "Unassigned"))
                report["edges"] += 1
            except KeyError as e:
                report["errors"].append(f"BELONGS_TO edge {item['item_id']}: {e}")

            # Edges: EXTRACTED_FROM documents
            for src in item.get("source_documents", []):
                doc_id = src.get("doc_id", "")
                if doc_id and f"DOC:{doc_id}" in kg.G:
                    kg.link_scope_to_document(
                        item["item_id"], doc_id,
                        confidence  = src.get("confidence", 1.0),
                        anchor_text = src.get("anchor_text", ""),
                    )
                    report["edges"] += 1

            # Edges: GOVERNED_BY spec section
            spec = item.get("spec_section", "")
            if spec:
                kg.add_spec_section(spec, title="")
                kg.link_scope_to_spec(item["item_id"], spec)
                report["edges"] += 1

            # Edges: REFERENCES drawings
            for dwg in item.get("drawing_refs", []):
                kg.add_drawing(dwg)
                kg.link_scope_to_drawing(item["item_id"], dwg)
                report["edges"] += 1

    # ── 3. RFI Log → RFI nodes + BLOCKS + GENERATED_BY edges ────────────────
    rfi_path = Path(rfi_log_path)
    if rfi_path.exists():
        with open(rfi_path) as f:
            rfi_data = json.load(f)
        for rfi in rfi_data.get("rfis", []):
            kg.add_rfi(
                rfi_number   = rfi["rfi_number"],
                priority     = rfi.get("priority", "ADVISORY"),
                subject      = rfi.get("subject", ""),
                discipline   = rfi.get("discipline", ""),
                status       = rfi.get("status", "ISSUED"),
                response_due = rfi.get("response_due", ""),
                issued_by    = rfi.get("issued_by", ""),
                issued_to    = rfi.get("issued_to", ""),
            )
            report["rfis"] += 1

            # BLOCKS edges
            for item_id in rfi.get("affected_scope", []):
                scope_nid = f"SCOPE:{item_id}"
                if scope_nid in kg.G:
                    kg.link_rfi_blocks_scope(
                        rfi["rfi_number"], item_id,
                        priority=rfi.get("priority", ""),
                    )
                    report["edges"] += 1

    # ── 4. Submittal Log → Submittal nodes + REQUIRES edges ──────────────────
    sub_path = Path(submittal_log_path)
    if sub_path.exists():
        with open(sub_path) as f:
            sub_data = json.load(f)
        for sub in sub_data.get("submittals", []):
            kg.add_submittal(
                submittal_number = sub["submittal_number"],
                spec_section     = sub.get("spec_section", ""),
                submittal_type   = sub.get("submittal_type", "SHOP_DRAWING"),
                disposition      = sub.get("disposition", "PENDING"),
                required_on_site = sub.get("required_on_site", ""),
            )
            report["submittals"] += 1
            spec = sub.get("spec_section", "")
            if spec:
                clean = spec.replace(" ", ".")
                if f"SPEC:{clean}" in kg.G:
                    kg.link_spec_requires_submittal(
                        spec, sub["submittal_number"],
                        lead_days      = sub.get("lead_days", 0),
                        submittal_type = sub.get("submittal_type", ""),
                    )
                    report["edges"] += 1

    # ── Summary ───────────────────────────────────────────────────────────────
    print(f"Graph population complete for project {kg.project_id}")
    print(f"  Documents:   {report['documents']:>4}")
    print(f"  Scope Items: {report['scope_items']:>4}")
    print(f"  RFIs:        {report['rfis']:>4}")
    print(f"  Submittals:  {report['submittals']:>4}")
    print(f"  Edges:       {report['edges']:>4}")
    if report["errors"]:
        print(f"  Errors:      {len(report['errors'])}")
        for e in report["errors"][:5]:
            print(f"    {e}")
    return report
