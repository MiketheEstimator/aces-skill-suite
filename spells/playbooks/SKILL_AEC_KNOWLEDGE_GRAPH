def build_project_kg(
    project_id:           str,
    corpus_registry_path: str,
    scope_baseline_path:  str,
    rfi_log_path:         str,
    submittal_log_path:   str,
    output_dir:           str = ".",
) -> AECKnowledgeGraph:
    """
    Full pipeline: populate → analyse → export.
    Run after each pipeline session to keep the KG current.
    """
    from pathlib import Path
    Path(output_dir).mkdir(parents=True, exist_ok=True)

    # 1. Initialise
    kg = AECKnowledgeGraph(project_id)

    # 2. Populate from pipeline outputs
    populate_from_pipeline_registers(
        kg,
        corpus_registry_path = corpus_registry_path,
        scope_baseline_path  = scope_baseline_path,
        rfi_log_path         = rfi_log_path,
        submittal_log_path   = submittal_log_path,
    )

    # 3. Print summary
    print_kg_summary(kg)

    # 4. Compute risk scores → write to JSON
    risks = compute_rfi_risk_scores(kg)
    Path(f"{output_dir}/kg_rfi_risk.json").write_text(
        json.dumps(risks, indent=2, default=str)
    )

    # 5. Costability report → write to JSON
    costability = costability_report(kg)
    Path(f"{output_dir}/kg_costability.json").write_text(
        json.dumps(costability, indent=2, default=str)
    )

    # 6. Blocked trades from superseded sources
    blocked = blocked_trades_from_superseded_sources(kg)
    Path(f"{output_dir}/kg_blocked_trades.json").write_text(
        json.dumps(blocked, indent=2, default=str)
    )

    # 7. Graph metrics
    metrics = compute_graph_metrics(kg)
    Path(f"{output_dir}/kg_metrics.json").write_text(
        json.dumps(metrics, indent=2, default=str)
    )

    # 8. Export snapshots
    export_json_snapshot(kg, f"{output_dir}/kg_snapshot.json")
    export_graphml(kg,       f"{output_dir}/kg_snapshot.graphml")
    export_cytoscape_json(kg, f"{output_dir}/kg_cytoscape.json")
    export_rdf_turtle(kg,    f"{output_dir}/kg_snapshot.ttl")

    print(f"\nKG outputs written to: {output_dir}")
    return kg


