import json
from pathlib import Path

# ── JSON snapshot ─────────────────────────────────────────────────────────────

def export_json_snapshot(kg: AECKnowledgeGraph,
                          output_path: str) -> None:
    """
    Export full graph as a JSON snapshot.
    Format: {nodes: [...], edges: [...], meta: {...}}
    Suitable for version control, diffing, and API responses.
    """
    nodes = [dict(data) for _, data in kg.G.nodes(data=True)]
    edges = []
    for u, v, key, data in kg.G.edges(data=True, keys=True):
        edges.append({
            "from": u, "to": v, "key": key,
            **{k: v2 for k, v2 in data.items()}
        })

    snapshot = {
        "meta":  kg.summary(),
        "nodes": nodes,
        "edges": edges,
    }
    Path(output_path).write_text(json.dumps(snapshot, indent=2, default=str))
    print(f"JSON snapshot: {output_path}  ({len(nodes)} nodes, {len(edges)} edges)")


# ── GraphML export (for Gephi, yEd, Cytoscape) ───────────────────────────────

def export_graphml(kg: AECKnowledgeGraph, output_path: str) -> None:
    """
    Export to GraphML. Gephi/yEd can import this directly for visual analysis.
    Note: NetworkX GraphML serializer requires all attribute values to be
    str, int, float, or bool — convert anything else before export.
    """
    G_clean = nx.MultiDiGraph()
    for nid, data in kg.G.nodes(data=True):
        clean = {k: (str(v) if not isinstance(v, (str, int, float, bool))
                     else v)
                 for k, v in data.items()}
        G_clean.add_node(nid, **clean)
    for u, v, key, data in kg.G.edges(data=True, keys=True):
        clean = {k: (str(v2) if not isinstance(v2, (str, int, float, bool))
                     else v2)
                 for k, v2 in data.items()}
        G_clean.add_edge(u, v, key=key, **clean)
    nx.write_graphml(G_clean, output_path)
    print(f"GraphML export: {output_path}")


# ── Cytoscape JSON (for web visualization) ────────────────────────────────────

def export_cytoscape_json(kg: AECKnowledgeGraph,
                           output_path: str,
                           subgraph: nx.MultiDiGraph = None) -> None:
    """
    Export to Cytoscape.js JSON format for web-based graph rendering.
    If subgraph is provided, only that subgraph is exported.
    """
    G = subgraph if subgraph is not None else kg.G

    elements = {"nodes": [], "edges": []}
    for nid, data in G.nodes(data=True):
        elements["nodes"].append({
            "data": {"id": nid, **{k: str(v) for k, v in data.items()}}
        })
    for u, v, key, data in G.edges(data=True, keys=True):
        elements["edges"].append({
            "data": {
                "id":     f"{u}__{v}__{key}",
                "source": u, "target": v,
                **{k: str(v2) for k, v2 in data.items()}
            }
        })
    Path(output_path).write_text(json.dumps(elements, indent=2))
    print(f"Cytoscape JSON: {output_path}")


# ── RDF/Turtle export (for ontology tools) ───────────────────────────────────

def export_rdf_turtle(kg: AECKnowledgeGraph,
                       output_path: str,
                       base_uri: str = "https://aec-kg.internal/") -> None:
    """
    Export graph as RDF Turtle. Pairs with SKILL_DATABASE_ONTOLOGY_EXPORT.
    Each node → an RDF resource; each edge → an RDF triple.
    """
    lines = [
        "@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .",
        "@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .",
        "@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .",
        f"@prefix aec:  <{base_uri}> .",
        "@prefix aecr: <https://aec-kg.internal/rel/> .",
        "",
    ]

    def uri(node_id: str) -> str:
        safe = node_id.replace(":", "_").replace(" ", "_").replace("/", "_")
        return f"aec:{safe}"

    # Nodes
    for nid, data in kg.G.nodes(data=True):
        u = uri(nid)
        lines.append(f"{u}")
        lines.append(f"    a aec:{data.get('node_type', 'Node')} ;")
        lines.append(f'    rdfs:label "{nid}"^^xsd:string ;')
        for k, v in data.items():
            if k in ("node_type", "node_id"):
                continue
            safe_v = str(v).replace('"', '\\"')
            lines.append(f'    aec:{k} "{safe_v}"^^xsd:string ;')
        lines[-1] = lines[-1].rstrip(";") + " ."
        lines.append("")

    # Edges
    for u_id, v_id, data in kg.G.edges(data=True):
        rel = data.get("rel_type", "RELATED_TO")
        lines.append(f"{uri(u_id)} aecr:{rel} {uri(v_id)} .")

    Path(output_path).write_text("\n".join(lines))
    print(f"RDF Turtle export: {output_path}")


# ── Delta / diff between two snapshots ───────────────────────────────────────

def diff_snapshots(old_path: str, new_path: str) -> dict:
    """
    Compare two JSON snapshots. Returns added/removed nodes and edges.
    Useful for change tracking between pipeline runs.
    """
    with open(old_path) as f:
        old = json.load(f)
    with open(new_path) as f:
        new = json.load(f)

    old_node_ids = {n["node_id"] for n in old["nodes"]}
    new_node_ids = {n["node_id"] for n in new["nodes"]}

    def edge_key(e):
        return (e.get("from"), e.get("to"), e.get("rel_type"))

    old_edge_keys = {edge_key(e) for e in old["edges"]}
    new_edge_keys = {edge_key(e) for e in new["edges"]}

    return {
        "nodes_added":   sorted(new_node_ids - old_node_ids),
        "nodes_removed": sorted(old_node_ids - new_node_ids),
        "edges_added":   sorted(str(k) for k in (new_edge_keys - old_edge_keys)),
        "edges_removed": sorted(str(k) for k in (old_edge_keys - new_edge_keys)),
    }
