## NetworkX Implementation

NetworkX is the right choice for in-memory, single-session, or CI graph work.
Use when: graph fits in RAM, no concurrent writers, scripts are Python-first.

### Graph Initialization

```python
import networkx as nx
from datetime import datetime, date
from typing import Any
import json

class AECKnowledgeGraph:
    """
    In-memory AEC Knowledge Graph backed by NetworkX MultiDiGraph.
    MultiDiGraph: directed, allows multiple edges between same node pair
    (e.g. a ScopeItem can REFERENCES multiple Drawings).
    """

    def __init__(self, project_id: str):
        self.project_id = project_id
        self.G = nx.MultiDiGraph(
            project_id = project_id,
            created_at = datetime.utcnow().isoformat(),
        )
        self._node_index: dict[str, dict] = {}  # node_id → attrs for fast lookup

    # ── Node addition ─────────────────────────────────────────────────────────

    def add_node(self, node_id: str, node_type: str, **attrs) -> str:
        """
        Add or update a node. Returns node_id.
        Merges attrs with existing node data (upsert semantics).
        """
        base = {
            "node_id":    node_id,
            "node_type":  node_type,
            "project_id": self.project_id,
            "created_at": datetime.utcnow().isoformat(),
        }
        base.update(attrs)

        if node_id in self.G:
            self.G.nodes[node_id].update(base)
        else:
            self.G.add_node(node_id, **base)

        self._node_index[node_id] = self.G.nodes[node_id]
        return node_id

    # ── Typed node helpers ────────────────────────────────────────────────────

    def add_document(self, doc_id: str, family: str, title: str,
                      issue_date: str = "", status: str = "CURRENT",
                      file_path: str = "", **kwargs) -> str:
        return self.add_node(
            f"DOC:{doc_id}", "Document",
            doc_id=doc_id, family=family, title=title,
            issue_date=issue_date, status=status, file_path=file_path,
            **kwargs
        )

    def add_scope_item(self, item_id: str, trade: str, description: str,
                        csi_division: str, condition_class: str,
                        evidence_status: str, cost_ability: str,
                        **kwargs) -> str:
        return self.add_node(
            f"SCOPE:{item_id}", "ScopeItem",
            item_id=item_id, trade=trade, description=description,
            csi_division=csi_division, condition_class=condition_class,
            evidence_status=evidence_status, cost_ability=cost_ability,
            **kwargs
        )

    def add_rfi(self, rfi_number: str, priority: str, subject: str,
                 discipline: str, status: str, response_due: str,
                 **kwargs) -> str:
        return self.add_node(
            f"RFI:{rfi_number}", "RFI",
            rfi_number=rfi_number, priority=priority, subject=subject,
            discipline=discipline, status=status, response_due=response_due,
            **kwargs
        )

    def add_submittal(self, submittal_number: str, spec_section: str,
                       submittal_type: str, disposition: str,
                       required_on_site: str = "", **kwargs) -> str:
        return self.add_node(
            f"SUB:{submittal_number}", "Submittal",
            submittal_number=submittal_number, spec_section=spec_section,
            submittal_type=submittal_type, disposition=disposition,
            required_on_site=required_on_site, **kwargs
        )

    def add_trade(self, name: str, **kwargs) -> str:
        return self.add_node(f"TRADE:{name}", "Trade", name=name, **kwargs)

    def add_spec_section(self, section_number: str, title: str,
                          **kwargs) -> str:
        clean = section_number.replace(" ", ".")
        return self.add_node(
            f"SPEC:{clean}", "SpecSection",
            section_number=section_number, title=title, **kwargs
        )

    def add_drawing(self, drawing_number: str, title: str = "",
                     discipline: str = "", **kwargs) -> str:
        return self.add_node(
            f"DWG:{drawing_number}", "Drawing",
            drawing_number=drawing_number, title=title,
            discipline=discipline, **kwargs
        )

    def add_person(self, name: str, role: str = "",
                    organization: str = "", **kwargs) -> str:
        node_id = f"PERSON:{name}.{organization}" if organization else f"PERSON:{name}"
        return self.add_node(
            node_id, "Person",
            name=name, role=role, organization=organization, **kwargs
        )

    def add_organization(self, name: str, role: str = "", **kwargs) -> str:
        return self.add_node(
            f"ORG:{name}", "Organization", name=name, role=role, **kwargs
        )

    def add_zone(self, zone_id: str, description: str = "",
                  level: str = "", **kwargs) -> str:
        return self.add_node(
            f"ZONE:{zone_id}", "Zone",
            zone_id=zone_id, description=description, level=level, **kwargs
        )

    def add_gis_feature(self, feature_id: str, feature_type: str,
                          geometry_type: str = "", **kwargs) -> str:
        return self.add_node(
            f"GIS:{feature_id}", "GISFeature",
            feature_id=feature_id, feature_type=feature_type,
            geometry_type=geometry_type, **kwargs
        )

    def add_conflict(self, conflict_id: str, field: str,
                      value_a: str, value_b: str,
                      doc_a_id: str, doc_b_id: str, **kwargs) -> str:
        return self.add_node(
            f"CONFLICT:{conflict_id}", "Conflict",
            conflict_id=conflict_id, field=field,
            value_a=value_a, value_b=value_b,
            doc_a_id=doc_a_id, doc_b_id=doc_b_id, **kwargs
        )

    # ── Edge addition ─────────────────────────────────────────────────────────

    def add_edge(self, from_id: str, to_id: str, rel_type: str,
                  confidence: float = 1.0, source: str = "pipeline",
                  evidence: str = "", **attrs) -> None:
        """
        Add a directed edge. Raises KeyError if either node is missing.
        """
        if from_id not in self.G:
            raise KeyError(f"Source node not found: {from_id}")
        if to_id not in self.G:
            raise KeyError(f"Target node not found: {to_id}")
        self.G.add_edge(
            from_id, to_id,
            rel_type   = rel_type,
            confidence = confidence,
            source     = source,
            evidence   = evidence,
            created_at = datetime.utcnow().isoformat(),
            **attrs
        )

    # ── Typed edge helpers ────────────────────────────────────────────────────

    def link_scope_to_document(self, item_id: str, doc_id: str,
                                 confidence: float = 1.0,
                                 anchor_text: str = "", page: int = 0) -> None:
        self.add_edge(
            f"SCOPE:{item_id}", f"DOC:{doc_id}",
            rel_type="EXTRACTED_FROM",
            confidence=confidence, evidence=anchor_text, page=page,
        )

    def link_contradiction(self, doc_a_id: str, doc_b_id: str,
                             field: str, value_a: str, value_b: str,
                             conflict_id: str) -> None:
        self.add_edge(
            f"DOC:{doc_a_id}", f"DOC:{doc_b_id}",
            rel_type="CONTRADICTS",
            field=field, value_a=value_a, value_b=value_b,
            conflict_id=conflict_id,
        )

    def link_supersession(self, newer_doc_id: str, older_doc_id: str,
                           issue_date: str = "") -> None:
        self.add_edge(
            f"DOC:{newer_doc_id}", f"DOC:{older_doc_id}",
            rel_type="SUPERSEDES", issue_date=issue_date,
        )

    def link_rfi_blocks_scope(self, rfi_number: str, item_id: str,
                               priority: str = "") -> None:
        self.add_edge(
            f"RFI:{rfi_number}", f"SCOPE:{item_id}",
            rel_type="BLOCKS", priority=priority,
        )

    def link_scope_to_drawing(self, item_id: str, drawing_number: str,
                               detail: str = "") -> None:
        self.add_edge(
            f"SCOPE:{item_id}", f"DWG:{drawing_number}",
            rel_type="REFERENCES", detail=detail,
        )

    def link_scope_to_spec(self, item_id: str,
                            section_number: str) -> None:
        clean = section_number.replace(" ", ".")
        self.add_edge(
            f"SCOPE:{item_id}", f"SPEC:{clean}",
            rel_type="GOVERNED_BY",
        )

    def link_scope_to_trade(self, item_id: str, trade_name: str) -> None:
        self.add_edge(
            f"SCOPE:{item_id}", f"TRADE:{trade_name}",
            rel_type="BELONGS_TO",
        )

    def link_rfi_conflict(self, rfi_number: str, conflict_id: str) -> None:
        self.add_edge(
            f"RFI:{rfi_number}", f"CONFLICT:{conflict_id}",
            rel_type="GENERATED_BY",
        )

    def link_spec_requires_submittal(self, section_number: str,
                                      submittal_number: str,
                                      lead_days: int = 0,
                                      submittal_type: str = "") -> None:
        clean = section_number.replace(" ", ".")
        self.add_edge(
            f"SPEC:{clean}", f"SUB:{submittal_number}",
            rel_type="REQUIRES",
            lead_days=lead_days, submittal_type=submittal_type,
        )

    def link_scope_to_zone(self, item_id: str, zone_id: str,
                            confidence: float = 1.0) -> None:
        self.add_edge(
            f"SCOPE:{item_id}", f"ZONE:{zone_id}",
            rel_type="LOCATED_IN", confidence=confidence,
        )

    def link_scope_to_gis(self, item_id: str, feature_id: str,
                           distance_m: float = 0.0) -> None:
        self.add_edge(
            f"SCOPE:{item_id}", f"GIS:{feature_id}",
            rel_type="CORRESPONDS_TO", distance_m=distance_m,
        )

    # ── Lookups ───────────────────────────────────────────────────────────────

    def node(self, node_id: str) -> dict:
        """Return node attribute dict. Raises KeyError if missing."""
        return self.G.nodes[node_id]

    def nodes_of_type(self, node_type: str) -> list[dict]:
        return [
            data for _, data in self.G.nodes(data=True)
            if data.get("node_type") == node_type
        ]

    def edges_of_type(self, rel_type: str) -> list[tuple]:
        """Return list of (from_id, to_id, attrs) for edges of a given type."""
        return [
            (u, v, d)
            for u, v, d in self.G.edges(data=True)
            if d.get("rel_type") == rel_type
        ]

    def neighbors_of_type(self, node_id: str,
                            rel_type: str = None,
                            node_type: str = None,
                            direction: str = "out") -> list[dict]:
        """
        Return neighbor nodes, optionally filtered by edge type and/or node type.
        direction: 'out' (successors), 'in' (predecessors), 'both'
        """
        if direction == "out":
            neighbors = list(self.G.successors(node_id))
        elif direction == "in":
            neighbors = list(self.G.predecessors(node_id))
        else:
            neighbors = list(self.G.successors(node_id)) + \
                        list(self.G.predecessors(node_id))

        result = []
        for nid in neighbors:
            # Filter by edge type
            if rel_type:
                edges = (
                    self.G.get_edge_data(node_id, nid) or
                    self.G.get_edge_data(nid, node_id) or {}
                )
                has_rel = any(
                    e.get("rel_type") == rel_type
                    for e in edges.values()
                )
                if not has_rel:
                    continue
            # Filter by node type
            ndata = self.G.nodes[nid]
            if node_type and ndata.get("node_type") != node_type:
                continue
            result.append(ndata)
        return result

    # ── Summary ───────────────────────────────────────────────────────────────

    def summary(self) -> dict:
        node_counts = {}
        for _, data in self.G.nodes(data=True):
            t = data.get("node_type", "Unknown")
            node_counts[t] = node_counts.get(t, 0) + 1

        edge_counts = {}
        for _, _, data in self.G.edges(data=True):
            t = data.get("rel_type", "Unknown")
            edge_counts[t] = edge_counts.get(t, 0) + 1

        return {
            "project_id":   self.project_id,
            "total_nodes":  self.G.number_of_nodes(),
            "total_edges":  self.G.number_of_edges(),
            "node_counts":  node_counts,
            "edge_counts":  edge_counts,
        }
