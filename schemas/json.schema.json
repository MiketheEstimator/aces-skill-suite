{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aces.local/schemas/json.schema.json",
  "title": "Generic JSON Artifact Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "file_name",
    "mime_type",
    "record_count",
    "strict_contract"
  ],
  "properties": {
    "artifact_type": { "const": "json" },
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "file_name": { "type": "string", "pattern": "^[^\\/]+\\.json$" },
    "mime_type": { "const": "application/json" },
    "record_count": { "type": "integer", "minimum": 0 },
    "strict_contract": { "type": "boolean", "const": true },
    "checksum_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
  }
}
