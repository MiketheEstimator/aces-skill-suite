{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aces.local/schemas/docx.schema.json",
  "title": "DOCX Artifact Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "file_name",
    "mime_type",
    "author",
    "title",
    "sections",
    "smart_quotes_encoded"
  ],
  "properties": {
    "artifact_type": { "const": "docx" },
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "file_name": { "type": "string", "pattern": "^[^\\/]+\\.docx$" },
    "mime_type": { "const": "application/vnd.openxmlformats-officedocument.wordprocessingml.document" },
    "author": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "smart_quotes_encoded": { "type": "boolean", "const": true },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["heading", "paragraph_count"],
        "properties": {
          "heading": { "type": "string", "minLength": 1 },
          "paragraph_count": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
