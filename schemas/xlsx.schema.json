{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aces.local/schemas/xlsx.schema.json",
  "title": "XLSX Artifact Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "file_name",
    "mime_type",
    "sheet_names",
    "input_color_rgb",
    "formula_color_rgb",
    "contains_formula_errors"
  ],
  "properties": {
    "artifact_type": { "const": "xlsx" },
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "file_name": { "type": "string", "pattern": "^[^\\/]+\\.xlsx$" },
    "mime_type": { "const": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" },
    "sheet_names": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "input_color_rgb": { "const": "0000FF" },
    "formula_color_rgb": { "const": "000000" },
    "contains_formula_errors": { "type": "boolean", "const": false }
  }
}
